        <p>
            <i>Shop nick liên quân, mua acc liên quân 9k, thử vận may liên quân vip, bán tài khoản liên quân uy tín, săn acc lq giá rẻ, shop acc liên quân trắng thông tin, mua nick lq mobile.</i>
        </p>
    </section>

    <div id="infoModal" class="custom-modal">
        <div class="custom-content" id="infoModalBorder">
            <div id="infoModalIconBox" style="width: 70px; height: 70px; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 20px;">
                <i id="infoModalIcon" class="" style="font-size: 35px;"></i>
            </div>
            <h2 id="infoModalTitle" style="color: #fff; margin-bottom: 10px; font-size: 20px;">Thông Báo</h2>
            <p id="infoModalDesc" style="color: #a0aec0; font-size: 14px; margin-bottom: 25px;">Nội dung chi tiết...</p>
            
            <div id="infoModalAction">
                </div>
        </div>
    </div>

    <%- include('../../includes/footer') %>
    <%- include('../../includes/modals') %>

    <script>
        // Đồng hồ đếm ngược
        let currentServerTime = <%= serverTime %>;
        setInterval(() => { currentServerTime += 1000; }, 1000);

        function updateTimers() {
            const timers = document.querySelectorAll('.countdown-box[data-time]');
            timers.forEach(box => {
                const id = box.id.split('-')[1];
                const btn = document.getElementById('btn-' + id);
                const saleTime = parseInt(box.getAttribute('data-time'));
                const distance = saleTime - currentServerTime;

                if (distance <= 0) {
                    box.innerHTML = "MỞ BÁN RỒI! MUA NGAY!";
                    box.style.color = "#f1c40f";
                    box.style.borderColor = "#f1c40f";
                    
                    if(btn.disabled) {
                        btn.disabled = false;
                        btn.className = "btn-fs btn-buy-now";
                        btn.innerText = "🔥 CLICK MUA NGAY 🔥";
                        btn.onclick = () => buyFlashSale(id);
                    }
                } else {
                    const days = Math.floor(distance / (1000 * 60 * 60 * 24));
                    const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
                    const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
                    const seconds = Math.floor((distance % (1000 * 60)) / 1000);
                    
                    if(days > 0) {
                        box.innerHTML = `Còn: ${days}d ${hours}h ${minutes}m ${seconds}s`;
                    } else {
                        box.innerHTML = `Còn: ${hours}h ${minutes}m ${seconds}s`;
                    }
                }
            });
        }
        setInterval(updateTimers, 1000);
        updateTimers();

        // ==========================================
        // CÁC HÀM XỬ LÝ MODAL THÔNG BÁO XỊN XÒ
        // ==========================================
        function showCustomInfoModal(type, title, desc, actionHtml) {
            const modal = document.getElementById('infoModal');
            const boxBorder = document.getElementById('infoModalBorder');
            const iconBox = document.getElementById('infoModalIconBox');
            const icon = document.getElementById('infoModalIcon');
            
            document.getElementById('infoModalTitle').innerText = title;
            document.getElementById('infoModalDesc').innerHTML = desc;
            document.getElementById('infoModalAction').innerHTML = actionHtml;

            if(type === 'error') {
                boxBorder.style.borderColor = '#e74c3c';
                iconBox.style.background = 'rgba(231, 76, 60, 0.1)';
                icon.className = 'fa-solid fa-circle-xmark';
                icon.style.color = '#e74c3c';
            } 
            else if(type === 'warning') {
                boxBorder.style.borderColor = '#f1c40f';
                iconBox.style.background = 'rgba(241, 196, 15, 0.1)';
                icon.className = 'fa-solid fa-triangle-exclamation';
                icon.style.color = '#f1c40f';
            }
            else {
                boxBorder.style.borderColor = '#00f2c3';
                iconBox.style.background = 'rgba(0, 242, 195, 0.1)';
                icon.className = 'fa-solid fa-check-circle';
                icon.style.color = '#00f2c3';
            }
            modal.style.display = 'flex';
        }

        function closeInfoModal() {
            document.getElementById('infoModal').style.display = 'none';
        }

        // Tắt Modal khi nhấn ra vùng viền đen
        window.onclick = function(event) {
            const infoModal = document.getElementById('infoModal');
            if (event.target == infoModal) closeInfoModal();
        }

        // ==========================================
        // LOGIC MUA HÀNG KHÔNG DÙNG ALERT MẶC ĐỊNH NỮA
        // ==========================================
        async function buyFlashSale(productId) {
            const isLogged = <%= typeof user !== 'undefined' && user ? 'true' : 'false' %>;
            
            // XỬ LÝ TRƯỜNG HỢP CHƯA ĐĂNG NHẬP
            if(!isLogged) {
                showCustomInfoModal(
                    'warning', 
                    'Chưa Đăng Nhập!', 
                    'Sếp cần phải đăng nhập tài khoản để có thể đua top săn Acc 1đ nhé.', 
                    `<button class="btn-fs btn-buy-now" style="width:100%; border:none; padding:15px; font-size:15px;" onclick="window.location.href='/auth/login'">ĐĂNG NHẬP NGAY</button>`
                );
                return;
            }

            const btn = document.getElementById('btn-' + productId);
            btn.innerText = "ĐANG XỬ LÝ...";
            btn.disabled = true;

            // HIỆN THÔNG BÁO CHỜ XỬ LÝ
            showCustomInfoModal(
                'warning', 
                'Đang Xử Lý...', 
                'Hệ thống đang giành giật Acc cho sếp, xin vui lòng chờ 1 lát <i class="fa-solid fa-spinner fa-spin"></i>', 
                ``
            );

            try {
                const res = await fetch('/san-acc-1d/buy', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'CSRF-Token': document.querySelector('meta[name="csrf-token"]').getAttribute('content')
                    },
                    body: JSON.stringify({ productId })
                });

                const data = await res.json();
                
                if(data.success) {
                    // MUA THÀNH CÔNG
                    showCustomInfoModal(
                        'success', 
                        '🎉 SĂN THÀNH CÔNG!', 
                        data.message, 
                        `<button class="btn-fs btn-buy-now" style="width:100%; border:none; background: #00f2c3; color: #000; padding:15px; font-size:15px;" onclick="window.location.href='/user/lich-su-mua-hang'">VÀO KHO LẤY NICK</button>`
                    );
                } else {
                    // MUA THẤT BẠI (Do chậm tay hoặc chưa đủ 10k)
                    let actionBtn = `<button class="btn-fs" style="width: 100%; background: #4a5568; color: #fff; padding:15px;" onclick="window.location.reload()">ĐÓNG VÀ TẢI LẠI TRANG</button>`;
                    
                    if(data.message.toLowerCase().includes("nạp") || data.message.toLowerCase().includes("1đ")) {
                        actionBtn = `<a href="/#nap-the" class="btn-fs btn-buy-now" style="display:block; text-align:center; text-decoration:none; padding:15px; font-size:15px;">NẠP THÊM LÚA NGAY</a>`;
                    }

                    showCustomInfoModal('error', 'Rất Tiếc!', data.message, actionBtn);
                    btn.innerText = "🔥 CLICK MUA NGAY 🔥";
                    btn.disabled = false;
                }
            } catch (err) {
                // LỖI MẠNG
                showCustomInfoModal(
                    'error', 
                    'Mất Kết Nối', 
                    'Lỗi mạng hoặc máy chủ đang quá tải vì có quá nhiều người săn cùng lúc. Vui lòng bấm thử lại.', 
                    `<button class="btn-fs" style="width: 100%; background: #4a5568; color: #fff; padding:15px;" onclick="closeInfoModal()">ĐÓNG</button>`
                );
                btn.innerText = "🔥 CLICK MUA NGAY 🔥";
                btn.disabled = false;
            }
        }
    </script>
</body>
</html>