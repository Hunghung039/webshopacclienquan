<!DOCTYPE html>
<html lang="vi">
<head>
    <%- include('../../includes/head', locals) %>
    <meta name="description" content="Săn acc Liên Quân 1đ - Shop bán tài khoản Liên Quân giá rẻ, uy tín. Cơ hội nhận nick VIP chỉ với 1 VNĐ. Hệ thống giao dịch tự động, an toàn 100%.">
    <meta name="keywords" content="bán tài khoản liên quân giá rẻ, săn acc liên quân 1đ, shop nick liên quân, mua acc liên quân vip, nick liên quân 1k, shop acc liên quân uy tín">
    
    <style>
        .fs-bg { background: #0f111a; min-height: 100vh; color: #fff; padding-bottom: 60px; font-family: 'Be Vietnam Pro', sans-serif;}
        
        /* Banner & Header SEO */
        .fs-banner { background: linear-gradient(45deg, #c0392b, #8e44ad); padding: 50px 15px 40px; text-align: center; position: relative; overflow: hidden; }
        .fs-banner::before { content: ''; position: absolute; top:0; left:0; width: 100%; height: 100%; background: url('https://www.transparenttextures.com/patterns/stardust.png'); opacity: 0.3; }
        
        .fs-title { font-size: 38px; font-weight: 900; color: #f1c40f; text-transform: uppercase; margin: 0 0 10px; text-shadow: 0 5px 15px rgba(0,0,0,0.5); position: relative; z-index: 2;}
        .fs-subtitle { font-size: 18px; color: #ecf0f1; margin: 0 0 15px; position: relative; z-index: 2; font-weight: 500;}
        
        .rule-box { background: rgba(0,0,0,0.5); border: 1px solid #f1c40f; border-radius: 10px; max-width: 700px; margin: 20px auto 0; padding: 20px; position: relative; z-index: 2; text-align: left; font-size: 14px; color: #bdc3c7; line-height: 1.6; box-shadow: 0 5px 15px rgba(0,0,0,0.3);}
        .rule-box h2 { color: #f1c40f; font-size: 18px; margin: 0 0 10px 0; text-transform: uppercase; }

        /* Lưới Sản Phẩm */
        .fs-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; max-width: 1200px; margin: -30px auto 0; padding: 0 15px; position: relative; z-index: 5;}
        
        .fs-card { background: #1e2235; border-radius: 12px; overflow: hidden; border: 1px solid #2d3450; box-shadow: 0 10px 30px rgba(0,0,0,0.3); transition: all 0.3s ease; display: flex; flex-direction: column;}
        .fs-card:hover { transform: translateY(-5px); border-color: #e74c3c; box-shadow: 0 15px 40px rgba(231,76,60,0.4);}
        
        .fs-thumb { position: relative; padding-top: 56.25%; overflow: hidden; }
        .fs-thumb img { position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s ease; }
        .fs-card:hover .fs-thumb img { transform: scale(1.1); }
        
        .fs-price-tag { position: absolute; top: 10px; right: 10px; background: #e74c3c; color: #fff; font-weight: 900; font-size: 18px; padding: 5px 15px; border-radius: 20px; box-shadow: 0 4px 10px rgba(0,0,0,0.5); animation: pulse 1s infinite;}
        
        .fs-body { padding: 15px; text-align: center; flex: 1; display: flex; flex-direction: column;}
        .fs-name { font-size: 15px; font-weight: 700; color: #fff; margin-bottom: 15px; line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;}
        
        /* Đồng hồ đếm ngược */
        .countdown-box { background: rgba(0,0,0,0.4); padding: 8px; border-radius: 8px; margin-bottom: 12px; font-family: 'Courier New', Courier, monospace; font-size: 16px; font-weight: bold; color: #00f2c3; border: 1px dashed #00f2c3;}
        
        .btn-fs { margin-top: auto; padding: 12px; width: 100%; border-radius: 8px; font-size: 14px; font-weight: 800; border: none; cursor: pointer; text-transform: uppercase; transition: 0.3s;}
        
        /* Trạng thái nút */
        .btn-wait { background: #34495e; color: #95a5a6; cursor: not-allowed; }
        .btn-buy-now { background: linear-gradient(45deg, #f1c40f, #e67e22); color: #000; box-shadow: 0 4px 15px rgba(241,196,15,0.4); }
        .btn-buy-now:hover { transform: scale(1.05); }
        .btn-sold { background: #111; color: #e74c3c; border: 1px solid #e74c3c; cursor: not-allowed; }

        /* Vùng nội dung SEO chuẩn */
        .seo-content-box { max-width: 1200px; margin: 50px auto 0; padding: 30px 20px; background: #16192b; border-radius: 12px; border: 1px solid #2d3450; color: #a0a5b5; line-height: 1.8; }
        .seo-content-box h2, .seo-content-box h3 { color: #f1c40f; margin-bottom: 15px; }
        .seo-content-box h2 { font-size: 24px; text-transform: uppercase; text-align: center; border-bottom: 1px dashed #2d3450; padding-bottom: 15px;}
        .seo-content-box h3 { font-size: 18px; margin-top: 20px;}
        .seo-content-box ul { padding-left: 20px; }
        .seo-content-box a { color: #e74c3c; text-decoration: none; font-weight: bold; }
        .seo-content-box a:hover { text-decoration: underline; }

        @keyframes pulse { 0% { transform: scale(1); } 50% { transform: scale(1.1); } 100% { transform: scale(1); } }
        @keyframes slideDown { from { opacity: 0; transform: translateY(-30px); } to { opacity: 1; transform: translateY(0); } }

        /* CSS CHO MODAL THÔNG BÁO TÙY CHỈNH */
        .custom-modal { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.85); z-index: 9999; justify-content: center; align-items: center; padding: 15px; backdrop-filter: blur(5px);}
        .custom-content { background: #1a202c; max-width: 400px; width: 100%; border-radius: 20px; border: 2px solid #3182ce; padding: 40px 20px; position: relative; text-align: center; animation: slideDown 0.3s ease-out; }

        /* RESPONSIVE CHO MOBILE & TABLET */
        @media (max-width: 992px) {
            .fs-grid { grid-template-columns: repeat(3, 1fr); }
        }
        @media (max-width: 768px) {
            .fs-title { font-size: 24px; }
            .fs-subtitle { font-size: 14px; }
            .fs-grid { grid-template-columns: repeat(2, 1fr); gap: 10px; margin-top: 15px; padding: 0 10px; }
            .fs-card { border-radius: 8px; }
            .fs-body { padding: 10px; }
            .fs-name { font-size: 13px; margin-bottom: 10px; }
            .fs-price-tag { font-size: 14px; padding: 3px 8px; top: 5px; right: 5px; }
            .countdown-box { font-size: 12px; padding: 6px; }
            .btn-fs { padding: 8px; font-size: 12px; }
            .seo-content-box { margin: 30px 10px 0; padding: 20px 15px; }
            .seo-content-box h2 { font-size: 18px; }
        }
    </style>

    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebPage",
      "name": "Săn Acc Liên Quân 1đ - Mua Bán Tài Khoản Liên Quân Giá Rẻ",
      "description": "Sự kiện siêu sale săn nick Liên Quân VIP chỉ 1đ. Cửa hàng bán tài khoản Liên Quân giá rẻ, uy tín hàng đầu.",
      "mainEntity": {
        "@type": "SaleEvent",
        "name": "Giờ Vàng Săn Acc Liên Quân 1đ",
        "description": "Cơ hội rước siêu phẩm tài khoản Liên Quân Mobile giá hủy diệt chỉ với 1 VNĐ.",
        "image": "https://shoplienquan.site/images/banner-share.png",
        "startDate": "2024-01-01T00:00:00+07:00",
        "endDate": "2027-12-31T23:59:59+07:00",
        "eventStatus": "https://schema.org/EventScheduled",
        "eventAttendanceMode": "https://schema.org/OnlineEventAttendanceMode",
        "location": {
          "@type": "VirtualLocation",
          "url": "https://shoplienquan.site/san-acc-1d"
        },
        "organizer": {
          "@type": "Organization",
          "name": "Shop Liên Quân Uy Tín",
          "url": "https://shoplienquan.site"
        },
        "performer": {
          "@type": "Organization",
          "name": "Shop Liên Quân Uy Tín"
        },
        "offers": {
          "@type": "AggregateOffer",
          "url": "https://shoplienquan.site/san-acc-1d",
          "priceCurrency": "VND",
          "lowPrice": "1",
          "highPrice": "1",
          "offerCount": "<%= (typeof products !== 'undefined' && products.length > 0) ? products.length : 1 %>",
          "availability": "https://schema.org/InStock",
          "validFrom": "2024-01-01T00:00:00+07:00"
        }
      }
    }
    </script>
</head>
<body class="fs-bg">
    <%- include('../../includes/header') %>
    <%- include('../../includes/mobile-nav') %>

    <div class="fs-banner">
        <h1 class="fs-title">🔥 GIỜ VÀNG SĂN ACC 1Đ 🔥</h1>
        <p class="fs-subtitle">Shop bán tài khoản Liên Quân giá rẻ - Cơ hội rước siêu phẩm VIP chỉ với 1đ!</p>
        
        <div class="rule-box">
