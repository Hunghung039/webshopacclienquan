                <h2 class="section-title"><i class="fa-solid fa-wallet" style="color:#2ecc71"></i> NẠP THẺ / NẠP ATM TỰ ĐỘNG</h2>
            </div>
            <div class="recharge-wrapper">
                 <%- include('../../includes/partials/recharge-form') %> 
            </div>
        </section>

        <section class="news-zone aos-init">
            <div class="section-header">
                <h2 class="section-title"><i class="fa-solid fa-newspaper" style="color:#e67e22"></i> TIN TỨC & CẨM NANG</h2>
                <a href="/tin-tuc" class="btn-view-all">Xem tất cả <i class="fa-solid fa-angle-right"></i></a>
            </div>

            <div class="news-grid">
                <% if (typeof popularArticles !== 'undefined' && popularArticles.length > 0) { %>
                    <article>
                        <a href="/tin-tuc/<%= popularArticles[0].slug %>" title="<%= popularArticles[0].title %>" class="news-hot-card">
                            <img src="<%= popularArticles[0].thumbnail %>" alt="<%= popularArticles[0].title %>" loading="lazy">
                            <div class="news-hot-overlay">
                                <span class="news-tag-hot">Đáng chú ý</span>
                                <h3 class="news-hot-title"><%= popularArticles[0].title %></h3>
                            </div>
                        </a>
                    </article>
                <% } %>

                <div class="news-list-wrap">
                    <% if (typeof latestArticles !== 'undefined') { %>
                        <% latestArticles.forEach(function(article) { %>
                            <article>
                                <a href="/tin-tuc/<%= article.slug %>" title="<%= article.title %>" class="news-mini-card">
                                    <img src="<%= article.thumbnail %>" alt="<%= article.title %>" loading="lazy" class="news-mini-img">
                                    <div class="news-mini-content">
                                        <h3 class="news-mini-title"><%= article.title %></h3>
                                        <div class="news-mini-meta">
                                            <span><i class="fa-regular fa-clock"></i> <%= new Date(article.created_at).toLocaleDateString('vi-VN') %></span>
                                            <span><i class="fa-solid fa-fire" style="color:var(--game-primary);"></i> <%= article.views %></span>
                                        </div>
                                    </div>
                                </a>
                            </article>
                        <% }); %>
                    <% } %>
                </div>
            </div>
        </section>

        <article class="seo-content aos-init">
            <h1>Shop Acc Liên Quân - Túi Mù & Các Dịch Vụ Cày Thuê, Thuê Acc VIP Giá Rẻ</h1>
            <p>Chào mừng bạn đến với hệ thống <strong>Shop Acc Liên Quân</strong> tự động uy tín hàng đầu. Tại đây, chúng tôi mang đến cho bạn không chỉ là một nơi để mua tài khoản game, mà còn là một tổ hợp vũ trụ giải trí cực kỳ hấp dẫn. Nếu bạn thích trải nghiệm cảm giác mạnh, hãy tham gia ngay <strong>vòng quay túi mù liên quân</strong> với tỷ lệ trúng thưởng cực cao, hoặc thử vận may với <strong>sự kiện chung sức liên quân</strong> lật thẻ trúng skin SS.</p>
            
            <h2>Dịch Vụ Thuê Acc và Cày Thuê Rank Liên Quân Chuyên Nghiệp</h2>
            <p>Shop cung cấp dịch vụ <strong>Thuê Acc Liên Quân theo giờ</strong> giúp bạn trải nghiệm hàng loạt các skin bậc SSS, Tuyệt Sắc hiếm có (như Nakroth Thứ Nguyên Vệ Thần, Raz Muay Thái) chỉ với vài ngàn đồng. Bên cạnh đó, đội ngũ Thách Đấu của chúng tôi nhận <strong>Cày Thuê Rank Liên Quân</strong> siêu tốc, cam kết 100% cày tay, không sử dụng hack/mod, bảo mật tuyệt đối cho tài khoản của bạn.</p>
            
            <h3>Sự kiện Săn Acc 1đ và Nạp Thẻ Garena Chiết Khấu Cao</h3>
            <p>Đừng bỏ lỡ cơ hội <strong>săn acc liên quân 1đ</strong> tại shop. Chỉ với 1 VNĐ, bạn có cơ hội rước ngay tài khoản có Flo Tinh Hệ hay Ngộ Không Nhóc Tì. Đặc biệt, hệ thống <strong>bán thẻ garena giá rẻ</strong>, nạp tiền tự động bằng thẻ cào điện thoại hoặc ATM/Momo hoạt động 24/7 giúp bạn có ngay số dư để mua sắm chỉ trong vòng 3 giây.</p>
        </article>

    </main>

    <%- include('../../includes/footer') %>
    <%- include('../../includes/modals') %>
    <%- include('../../includes/scripts') %>

    <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // 1. Khởi tạo Slider cho Banner Chính Trên Cùng
            const mainSwiper = new Swiper('.banner-slider', {
                loop: true,
                autoplay: { 
                    delay: 4000, 
                    disableOnInteraction: false 
                },
                pagination: { 
                    el: '.swiper-pagination', 
                    clickable: true 
                },
                effect: 'fade', 
                fadeEffect: { crossFade: true }
            });

            // 2. Khởi tạo Slider cho Kho Tài Khoản ngang
            const accSwiper = new Swiper('.acc-slider-container', {
                slidesPerView: 2, /* Trên điện thoại hiện 2 card dọc */
                spaceBetween: 15,
                freeMode: true, /* Cho phép vuốt tự do, mượt mà */
                breakpoints: {
                    768: {
                        slidesPerView: 3,
                        spaceBetween: 20,
                    },
                    1024: {
                        slidesPerView: 4,
                        spaceBetween: 20,
                        freeMode: false,
                        navigation: true, 
                    }
                }
            });

            // 3. Khởi tạo hiệu ứng Fade-in Scroll (Tạo cảm giác App cao cấp)
            const aosElements = document.querySelectorAll('.aos-init');
            const observerOptions = {
                root: null,
                rootMargin: '0px',
                threshold: 0.1 // Hiện lên khi phần tử lộ diện 10%
            };

            const observer = new IntersectionObserver((entries, observer) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('aos-animate');
                        // Có thể bỏ theo dõi sau khi đã hiện để tối ưu hiệu năng
                        observer.unobserve(entry.target);
                    }
                });
            }, observerOptions);

            aosElements.forEach(el => {
                observer.observe(el);
            });
        });
    </script>

</body>
</html>