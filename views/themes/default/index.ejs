                </a>

            </div>
        </section>

        <section class="account-showcase-zone aos-init" id="shop-acc">
            <div class="section-header">
                <h2 class="section-title"><i class="fa-solid fa-store"></i> TÀI KHOẢN VIP VỪA LÊN KỆ</h2>
                <a href="/tai-khoan" class="btn-view-all">Xem tất cả <i class="fa-solid fa-angle-right"></i></a>
            </div>

            <div class="swiper acc-slider-container">
                <div class="swiper-wrapper">
                    <% if (typeof products !== 'undefined' && products.length > 0) { %>
                        <% products.slice(0, 10).forEach(function(product) { %>
                            <div class="swiper-slide">
                                <article class="acc-slide-card">
                                    <div class="acc-thumb">
                                        <div class="acc-tag-new">MỚI</div>
                                        <a href="/chi-tiet/<%= product.slug %>" title="<%= product.title %>">
                                            <img src="<%= product.image_url %>" alt="<%= product.title %>" loading="lazy">
                                        </a>
                                    </div>
                                    <div class="acc-info">
                                        <a href="/chi-tiet/<%= product.slug %>" style="text-decoration:none;">
                                            <h3 class="acc-name"><%= product.title %></h3>
                                        </a>
                                        <div class="acc-ms">Mã Số: <b>#<%= product.id %></b></div>
                                        
                                        <div class="acc-price-box">
                                            <% if (product.price_old > product.price_new) { %>
                                                <span class="acc-price-old"><%= new Intl.NumberFormat('vi-VN').format(product.price_old) %>đ</span>
                                            <% } %>
                                            <span class="acc-price-new"><%= new Intl.NumberFormat('vi-VN').format(product.price_new) %>đ</span>
                                        </div>
                                        
                                        <a href="/chi-tiet/<%= product.slug %>" class="btn-view-acc">
                                            XEM CHI TIẾT
                                        </a>
                                    </div>
                                </article>
                            </div>
                        <% }); %>
                    <% } else { %>
                        <div class="swiper-slide" style="width:100%; text-align:center; padding:40px; color:#95a5a6;">
                            <i class="fa-solid fa-ghost" style="font-size:40px; margin-bottom:10px;"></i>
                            <p>Kho Acc đang tạm trống, sếp quay lại sau nhé!</p>
