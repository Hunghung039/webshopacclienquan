<!DOCTYPE html>
<html lang="vi">
<head>
    <title>Cấu Hình Hệ Thống</title>
    <meta name="csrf-token" content="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
    
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <%- include('partials/admin_css') %>
</head>
<body>
    <%- include('partials/sidebar', { page: 'settings' }) %>

    <div class="main-content">
        <h1 style="margin: 0 0 25px 0; font-weight: 300; border-left: 4px solid var(--accent); padding-left: 15px;">Cấu Hình Hệ Thống</h1>
        
        <div class="card">
            <div class="tab-header">
                <button type="button" class="tab-btn active" onclick="switchTab(event, 'general')">Thông Tin Chung</button>
                <button type="button" class="tab-btn" onclick="switchTab(event, 'api')">API / Nạp Thẻ</button>
                <button type="button" class="tab-btn" onclick="switchTab(event, 'contact')">Liên Hệ & Ngân Hàng</button>
                <button type="button" class="tab-btn" onclick="switchTab(event, 'slider')">Quản Lý Slider</button>
                <button type="button" class="tab-btn" onclick="switchTab(event, 'qa')">Menu Nhanh</button>
            </div>

            <div id="tab-general" class="tab-content active">
                <form class="ajax-settings-form">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <div class="form-group"><label>Tên Website (SEO Title)</label><input type="text" name="site_title" value="<%= settings.site_title %>"></div>
                    <div class="form-group"><label>Link Logo (Dán URL)</label><input type="text" name="site_logo" value="<%= settings.site_logo %>"></div>
                    <div class="form-group"><label>Mô tả Web (SEO Description)</label><textarea name="site_description" rows="3"><%= settings.site_description %></textarea></div>
                    <div class="form-group"><label>Dòng thông báo chạy chữ (Header)</label><input type="text" name="notify_header" value="<%= settings.notify_header %>"></div>
                    <button type="submit" class="btn-save"><i class="fa-solid fa-save"></i> LƯU THÔNG TIN CHUNG</button>
                </form>
            </div>

            <div id="tab-api" class="tab-content">
                <form class="ajax-settings-form">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <div class="form-group"><label>Partner ID (Duyệt thẻ cào)</label><input type="text" name="card_api_id" value="<%= settings.card_api_id %>"></div>
                    <div class="form-group"><label>Partner Key</label><input type="password" name="card_api_key" value="<%= settings.card_api_key %>"></div>
                    <button type="submit" class="btn-save"><i class="fa-solid fa-key"></i> LƯU CẤU HÌNH API</button>
                </form>
            </div>

            <div id="tab-contact" class="tab-content">
                <form class="ajax-settings-form">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <div class="form-group"><label>Số Zalo Admin</label><input type="text" name="admin_zalo" value="<%= settings.admin_zalo %>"></div>
                    <div class="form-group"><label>Link Fanpage Facebook</label><input type="text" name="admin_facebook" value="<%= settings.admin_facebook %>"></div>
                    <div class="form-group"><label>Thông tin Ngân hàng (Dùng cho Nạp tay)</label><textarea name="bank_info" rows="4"><%= settings.bank_info %></textarea></div>
                    <button type="submit" class="btn-save"><i class="fa-solid fa-address-book"></i> LƯU LIÊN HỆ</button>
                </form>
            </div>

            <div id="tab-slider" class="tab-content">
                <div style="background: rgba(225, 78, 202, 0.05); padding: 20px; border-radius: 12px; border: 1px dashed var(--accent); margin-bottom: 25px;">
                    <h4 style="margin: 0 0 15px 0; font-size: 14px; color: var(--accent);"><i class="fa-solid fa-images"></i> THÊM BANNER SLIDER MỚI</h4>
                    <form id="add-banner-form" enctype="multipart/form-data">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 15px;">
                            <div>
                                <label>Cách 1: Upload file ảnh từ máy</label>
                                <div class="upload-box">
                                    <i class="fa-solid fa-cloud-arrow-up" style="font-size: 25px; color: #aaa; margin-bottom: 5px; display: block;"></i>
                                    <span style="font-size: 12px; color: #888;">Click chọn ảnh</span>
                                    <input type="file" name="banner_file" accept="image/*" style="opacity: 0; position: absolute; top:0; left:0; width:100%; height:100%; cursor: pointer;" onchange="previewBanner(event)">
                                    <img id="banner-preview" class="preview-img" alt="Xem trước">
                                </div>
                            </div>
                            <div>
                                <label>Cách 2: Dán Link ảnh (Gọn nhẹ máy chủ)</label>
                                <input type="text" name="image_url" placeholder="https://...">
                                
                                <label style="margin-top:15px;">Đường dẫn khi click vào ảnh (Link đích)</label>
                                <input type="text" name="link" placeholder="Mặc định: #">
                            </div>
                        </div>
                        <div style="text-align: right;">
                            <button type="submit" class="btn-save"><i class="fa-solid fa-cloud-arrow-up"></i> TẢI LÊN BANNER</button>
                        </div>
                    </form>
                </div>
                
                <table>
                    <thead><tr><th>HÌNH ẢNH BANNER</th><th>LIÊN KẾT ĐÍCH</th><th>HÀNH ĐỘNG</th></tr></thead>
                    <tbody id="banner-list">
                        <% banners.forEach(b => { %>
                            <tr id="banner-<%= b.id %>">
                                <td><img src="<%= b.image_url %>" style="width:160px; height:65px; object-fit:cover; border-radius:6px; border: 1px solid #444; box-shadow: 0 2px 5px rgba(0,0,0,0.2);"></td>
                                <td style="color:#888; font-size: 12px;"><%= b.link %></td>
                                <td><button class="btn-danger" onclick="deleteBanner('<%= b.id %>')"><i class="fa-solid fa-trash-can"></i> Xóa</button></td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>

            <div id="tab-qa" class="tab-content">
                <p style="font-size: 13px; color: #aaa; margin-bottom: 20px;"><i class="fa-solid fa-circle-info"></i> Quản lý các nút menu di chuyển nhanh tại trang chủ. Lấy icon tại FontAwesome 6.</p>
                <div id="qa-list">
                    <% quickActions.forEach(qa => { %>
                        <div class="qa-item-row" id="qa-<%= qa.id %>">
                            <div class="form-group"><label>Tiêu đề</label><input type="text" class="qa-title" value="<%= qa.title %>"></div>
                            <div class="form-group"><label>Icon Class (VD: fa-solid fa-fire)</label><input type="text" class="qa-icon" value="<%= qa.icon_class %>"></div>
                            <div class="form-group"><label>Đường dẫn đích</label><input type="text" class="qa-link" value="<%= qa.link_url %>"></div>
                            <button type="button" class="btn-save" onclick="updateQA('<%= qa.id %>')" style="padding: 10px; font-size: 12px; width: 100%; justify-content:center;">LƯU</button>
                        </div>
                    <% }) %>
                </div>
            </div>

        </div>
    </div>

    <script>
        const csrfToken = document.querySelector('meta[name="csrf-token"]').getAttribute('content');
        
        // 1. Chuyển Tab Mượt Mà
        function switchTab(event, t) {
            document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
            document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
            event.currentTarget.classList.add('active');
            document.getElementById('tab-' + t).classList.add('active');
        }

        // TÍNH NĂNG MỚI: Xem trước Banner
        function previewBanner(event) {
            const reader = new FileReader();
            reader.onload = function(){
                const output = document.getElementById('banner-preview');
                output.src = reader.result;
                output.style.display = 'block';
            };
            if(event.target.files[0]) {
                reader.readAsDataURL(event.target.files[0]);
            }
        }

        // 2. AJAX Lưu Settings Chung
        document.querySelectorAll('.ajax-settings-form').forEach(form => {
            form.addEventListener('submit', async (e) => {
                e.preventDefault();
                const btn = e.target.querySelector('.btn-save');
                const oldHTML = btn.innerHTML;
                btn.disabled = true;
                btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Đang lưu...';

                const data = Object.fromEntries(new FormData(e.target).entries());

                try {
                    const res = await fetch('/admin/settings/save', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'CSRF-Token': csrfToken // Thêm token vào đây
                        },
                        body: JSON.stringify(data)
                    });
                    const result = await res.json();
                    alert(result.message);
                } catch(err) { alert('Lỗi kết nối tới máy chủ!'); }
                finally { btn.disabled = false; btn.innerHTML = oldHTML; }
            });
        });

        // 3. AJAX Thêm Banner
        const bannerForm = document.getElementById('add-banner-form');
        if (bannerForm) {
            bannerForm.addEventListener('submit', async (e) => {
                e.preventDefault();
                const btn = e.target.querySelector('button[type="submit"]');
                const oldHTML = btn.innerHTML;
                btn.disabled = true;
                btn.innerHTML = '<i class="fa-solid fa-circle-notch fa-spin"></i> Đang tải lên...';

                const formData = new FormData(e.target);

                try {
                    const res = await fetch('/admin/banners/add', {
                        method: 'POST',
                        headers: {
                            'CSRF-Token': csrfToken // Thêm token vào đây
                        },
                        body: formData // Form Data đã bao gồm cả file vật lý
                    });
                    const result = await res.json();
                    if (result.success) { 
                        alert('Thêm Banner thành công!'); 
                        location.reload(); 
                    } else { 
                        alert('Lỗi: ' + result.message); 
                    }
                } catch (err) { alert('Lỗi kết nối trong quá trình tải ảnh!'); }
                finally { btn.disabled = false; btn.innerHTML = oldHTML; }
            });
        }

        // 4. Xóa Banner
        async function deleteBanner(id) {
            if(!confirm('Sếp có chắc chắn muốn xóa ảnh này khỏi Slider?')) return;
            try {
                const res = await fetch(`/admin/banners/delete/${id}`, { 
                    method: 'POST',
                    headers: { 'CSRF-Token': csrfToken } // Thêm token vào đây
                });
                const result = await res.json();
                if(result.success) {
                    const row = document.getElementById('banner-'+id);
                    row.style.transition = "0.3s";
                    row.style.opacity = "0";
                    setTimeout(() => row.remove(), 300);
                }
            } catch(e) { alert('Không thể xóa vào lúc này!'); }
        }

        // 5. Cập nhật Quick Action Menu
        async function updateQA(id) {
            const row = document.getElementById('qa-'+id);
            const btn = row.querySelector('button');
            const oldHTML = btn.innerHTML;
            btn.disabled = true;
            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i>';

            const data = {
                id: id,
                title: row.querySelector('.qa-title').value,
                icon_class: row.querySelector('.qa-icon').value,
                link_url: row.querySelector('.qa-link').value
            };

            try {
                const res = await fetch('/admin/quick-actions/update', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'CSRF-Token': csrfToken // Thêm token vào đây
                    },
                    body: JSON.stringify(data)
                });
                const result = await res.json();
                alert(result.message);
            } catch(e) { alert('Lỗi cập nhật Menu!'); }
            finally { btn.disabled = false; btn.innerHTML = oldHTML; }
        }
    </script>
</body>
</html>