<style>
    /* CSS Chỉ dành riêng cho thanh Sidebar */
    .sidebar { width: 250px; background: var(--sidebar); padding: 20px; display: flex; flex-direction: column; border-right: 1px solid rgba(255,255,255,0.1); flex-shrink: 0; transition: 0.3s ease-in-out; overflow-y: auto; height: 100vh; box-sizing: border-box; z-index: 1000;}
    .sidebar::-webkit-scrollbar { width: 5px; }
    .sidebar::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.2); border-radius: 10px; }

    .admin-logo { font-size: 24px; font-weight: 900; color: var(--text); margin-bottom: 30px; display: flex; align-items: center; gap: 10px; flex-shrink: 0;}
    .admin-logo span { color: var(--purple); }
    
    .menu-link { display: flex; align-items: center; gap: 12px; padding: 12px 15px; color: rgba(255,255,255,0.7); text-decoration: none; border-radius: 8px; transition: 0.3s; margin-bottom: 5px; font-size: 14px; font-weight: 600;}
    .menu-link:hover, .menu-link.active { background: var(--purple); color: #fff; box-shadow: 0 4px 15px rgba(225, 78, 202, 0.4); }
    .menu-link i { width: 20px; text-align: center; font-size: 16px; }
    
    /* Giao diện Nút bấm Mobile */
    .mobile-toggle { display: none; position: fixed; top: 15px; left: 15px; z-index: 1001; background: var(--sidebar); color: #fff; border: 1px solid rgba(255,255,255,0.1); padding: 10px 14px; border-radius: 8px; cursor: pointer; font-size: 18px; box-shadow: 0 4px 10px rgba(0,0,0,0.3); transition: 0.2s;}
    .sidebar-overlay { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.6); z-index: 999; backdrop-filter: blur(2px); opacity: 0; transition: 0.3s; }

    @media (max-width: 768px) {
        .mobile-toggle { display: block; }
        .sidebar-overlay.active { display: block; opacity: 1; }
        .sidebar { position: fixed; top: 0; left: -280px; width: 260px; box-shadow: none; }
        .sidebar.active { left: 0; box-shadow: 5px 0 25px rgba(0,0,0,0.5); }
    }
</style>

<button class="mobile-toggle" onclick="toggleSidebar()"><i class="fa-solid fa-bars"></i></button>
<div class="sidebar-overlay" onclick="toggleSidebar()"></div>

