<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="csrf-token" content="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
    <title>Admin Dashboard | Thống Kê Tổng Hợp</title>
    <link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@400;600;700;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <%- include('partials/admin_css') %>
</head>
<body>

    <%- include('partials/sidebar', { page: 'dashboard' }) %>

    <div class="main-content">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px;">
            <h1 style="margin: 0; font-weight: 300; border-left: 4px solid var(--accent); padding-left: 15px;">Thống Kê <b style="color: var(--accent);">Tài Chính Cấp Tốc</b></h1>
            <div class="header-actions">
                <button class="btn-tool" onclick="window.location.href='/admin'"><i class="fa-solid fa-rotate-right"></i> Reset (Xem Tất Cả)</button>
            </div>
        </div>

        <div style="background: #1a1a2e; padding: 20px; border-radius: 12px; margin-bottom: 30px; border: 1px solid var(--primary); box-shadow: 0 5px 15px rgba(0,0,0,0.3);">
            <form action="/admin" method="GET" style="display: flex; align-items: flex-end; gap: 15px; flex-wrap: wrap;">
                <div>
                    <label style="color: #aaa; font-size: 13px; font-weight: bold; display: block; margin-bottom: 5px;"><i class="fa-regular fa-clock"></i> Bắt đầu từ (Ngày & Giờ)</label>
                    <input type="datetime-local" name="start_time" value="<%= queryFilters.start_time || '' %>" required style="padding: 10px; border-radius: 6px; border: 1px solid #444; background: #000; color: #fff;">
                </div>
                <div>
                    <label style="color: #aaa; font-size: 13px; font-weight: bold; display: block; margin-bottom: 5px;"><i class="fa-regular fa-clock"></i> Kết thúc lúc (Ngày & Giờ)</label>
                    <input type="datetime-local" name="end_time" value="<%= queryFilters.end_time || '' %>" required style="padding: 10px; border-radius: 6px; border: 1px solid #444; background: #000; color: #fff;">
                </div>
                <button type="submit" style="background: var(--primary); color: #fff; font-weight: 900; padding: 12px 25px; border-radius: 6px; border: none; cursor: pointer;"><i class="fa-solid fa-filter"></i> LỌC KẾT QUẢ</button>
            </form>
        </div>

        <% if (queryFilters.start_time && queryFilters.end_time) { %>
            <h3 style="color: var(--warning); margin-bottom: 15px; background: rgba(241, 196, 15, 0.1); padding: 15px; border-radius: 8px; border-left: 4px solid var(--warning);">
                <i class="fa-solid fa-chart-line"></i> DỮ LIỆU TỪ 
                <b style="color:#fff;"><%= queryFilters.start_time.replace('T', ' lúc ') %></b> 
                ĐẾN 
                <b style="color:#fff;"><%= queryFilters.end_time.replace('T', ' lúc ') %></b>
            </h3>
        <% } else { %>
            <h3 style="color: #fff; margin-bottom: 15px;"><i class="fa-solid fa-earth-americas"></i> KẾT QUẢ TOÀN THỜI GIAN (TỪ TRƯỚC ĐẾN NAY)</h3>
        <% } %>

        <div style="display: grid; grid-template-columns: 1.5fr 1fr 1fr; gap: 20px; margin-bottom: 30px;">
            <div style="background: linear-gradient(135deg, #e74c3c, #c0392b); padding: 25px; border-radius: 15px; box-shadow: 0 10px 30px rgba(231,76,60,0.4);">
                <div style="color: #fff; font-size: 15px; font-weight: bold; margin-bottom: 5px; text-transform: uppercase;"><i class="fa-solid fa-sack-dollar"></i> LỢI NHUẬN THU VỀ (TỔNG KHÁCH TIÊU)</div>
                <div style="font-size: 40px; font-weight: 900; color: #fff;">
                    +<%= new Intl.NumberFormat('vi-VN').format(stats.profitTotal) %>đ
                </div>
            </div>

            <div style="background: var(--card); padding: 20px; border-radius: 12px; border-left: 4px solid var(--success);">
                <div style="color: #9a9a9a; font-size: 13px; font-weight: bold;"><i class="fa-solid fa-money-bill-transfer"></i> KHÁCH NẠP TỰ ĐỘNG</div>
                <div style="font-size: 26px; font-weight: 900; margin-top: 10px; color: var(--success);">
                    +<%= new Intl.NumberFormat('vi-VN').format(stats.autoDeposit) %>đ
                </div>
            </div>

            <div style="background: var(--card); padding: 20px; border-radius: 12px; border-left: 4px solid var(--warning);">
                <div style="color: #9a9a9a; font-size: 13px; font-weight: bold;"><i class="fa-solid fa-hand-holding-dollar"></i> ADMIN BƠM TAY</div>
                <div style="font-size: 26px; font-weight: 900; margin-top: 10px; color: var(--warning);">
                    +<%= new Intl.NumberFormat('vi-VN').format(stats.manualDeposit) %>đ
                </div>
            </div>
        </div>

        <h3 style="color: #fff; margin-bottom: 15px; border-bottom: 1px solid #333; padding-bottom: 10px;"><i class="fa-solid fa-layer-group" style="color: #3498db;"></i> BÁC CÁO CHI TIẾT TỪNG DỊCH VỤ</h3>
        
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 15px; margin-bottom: 30px;">
            <% if (typeof blindBoxStats !== 'undefined' && blindBoxStats.length > 0) { %>
                <% blindBoxStats.forEach(bag => { %>
                    <div style="background: var(--card); padding: 15px; border-radius: 12px; border-left: 4px solid #e14eca; box-shadow: 0 4px 10px rgba(0,0,0,0.1);">
                        <div style="color: #9a9a9a; font-size: 12px; font-weight: bold; text-transform: uppercase;"><i class="fa-solid fa-gift"></i> BÁN TÚI <%= bag.bag_name %></div>
                        <div style="margin-top: 10px; display: flex; justify-content: space-between; align-items: center;">
                            <span style="font-size: 13px; color: #888;">Đã bán:</span> 
                            <span style="color: #fff; font-size: 15px; font-weight: bold;"><%= new Intl.NumberFormat('vi-VN').format(bag.total_sold) %> <small style="color: #666;">túi</small></span>
                        </div>
                        <div style="margin-top: 5px; display: flex; justify-content: space-between; align-items: center; border-top: 1px dashed #333; padding-top: 5px;">
                            <span style="font-size: 13px; color: #888;">Thu về:</span> 
                            <span style="color: var(--success); font-size: 16px; font-weight: 900;">+<%= new Intl.NumberFormat('vi-VN').format(bag.total_revenue || 0) %>đ</span>
                        </div>
                    </div>
                <% }) %>
            <% } %>

            <div style="background: var(--card); padding: 15px; border-radius: 12px; border-left: 4px solid #f1c40f; box-shadow: 0 4px 10px rgba(0,0,0,0.1);">
                <div style="color: #9a9a9a; font-size: 12px; font-weight: bold;"><i class="fa-solid fa-yin-yang"></i> LẬT THẺ / GIEO QUẺ</div>
                <div style="margin-top: 10px; display: flex; justify-content: space-between; align-items: center;">
                    <span style="font-size: 13px; color: #888;">Đã chơi:</span> 
                    <span style="color: #fff; font-size: 15px; font-weight: bold;"><%= new Intl.NumberFormat('vi-VN').format(xinxamStats.total_sold || 0) %> <small style="color: #666;">lần</small></span>
                </div>
                <div style="margin-top: 5px; display: flex; justify-content: space-between; align-items: center; border-top: 1px dashed #333; padding-top: 5px;">
                    <span style="font-size: 13px; color: #888;">Thu về:</span> 
                    <span style="color: var(--success); font-size: 16px; font-weight: 900;">+<%= new Intl.NumberFormat('vi-VN').format(xinxamStats.total_revenue || 0) %>đ</span>
                </div>
            </div>

            <div style="background: var(--card); padding: 15px; border-radius: 12px; border-left: 4px solid #00cec9; box-shadow: 0 4px 10px rgba(0,0,0,0.1);">
                <div style="color: #9a9a9a; font-size: 12px; font-weight: bold;"><i class="fa-solid fa-khanda"></i> DỊCH VỤ CÀY THUÊ</div>
                <div style="margin-top: 10px; display: flex; justify-content: space-between; align-items: center;">
                    <span style="font-size: 13px; color: #888;">Số đơn đặt:</span> 
                    <span style="color: #fff; font-size: 15px; font-weight: bold;"><%= new Intl.NumberFormat('vi-VN').format(boostStats.total_sold || 0) %> <small style="color: #666;">đơn</small></span>
                </div>
                <div style="margin-top: 5px; display: flex; justify-content: space-between; align-items: center; border-top: 1px dashed #333; padding-top: 5px;">
                    <span style="font-size: 13px; color: #888;">Thu về:</span> 
                    <span style="color: var(--success); font-size: 16px; font-weight: 900;">+<%= new Intl.NumberFormat('vi-VN').format(boostStats.total_revenue || 0) %>đ</span>
                </div>
            </div>

            <div style="background: var(--card); padding: 15px; border-radius: 12px; border-left: 4px solid #fd79a8; box-shadow: 0 4px 10px rgba(0,0,0,0.1);">
                <div style="color: #9a9a9a; font-size: 12px; font-weight: bold;"><i class="fa-solid fa-clock"></i> DỊCH VỤ CHO THUÊ ACC</div>
                <div style="margin-top: 10px; display: flex; justify-content: space-between; align-items: center;">
                    <span style="font-size: 13px; color: #888;">Số phiên thuê:</span> 
                    <span style="color: #fff; font-size: 15px; font-weight: bold;"><%= new Intl.NumberFormat('vi-VN').format(rentAccStats.total_sold || 0) %> <small style="color: #666;">lần</small></span>
                </div>
                <div style="margin-top: 5px; display: flex; justify-content: space-between; align-items: center; border-top: 1px dashed #333; padding-top: 5px;">
                    <span style="font-size: 13px; color: #888;">Thu về:</span> 
                    <span style="color: var(--success); font-size: 16px; font-weight: 900;">+<%= new Intl.NumberFormat('vi-VN').format(rentAccStats.total_revenue || 0) %>đ</span>
                </div>
            </div>
        </div>

        <h3 style="color: #fff; margin-bottom: 15px; border-bottom: 1px solid #333; padding-bottom: 10px;"><i class="fa-solid fa-database" style="color: var(--primary);"></i> KHO HÀNG & USER HIỆN TẠI</h3>
        <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-bottom: 30px;">
            <div style="background: var(--card); padding: 25px; border-radius: 12px; border-left: 4px solid var(--primary);">
                <div style="color: #9a9a9a; font-size: 14px; font-weight: bold;"><i class="fa-solid fa-users"></i> TỔNG THÀNH VIÊN THẬT</div>
                <div style="font-size: 32px; font-weight: 900; margin-top: 10px;"><%= new Intl.NumberFormat('vi-VN').format(stats.userCount) %> <span style="font-size: 16px; color: #888;">Users</span></div>
            </div>

            <div style="background: var(--card); padding: 25px; border-radius: 12px; border-left: 4px solid var(--warning);">
                <div style="color: #9a9a9a; font-size: 14px; font-weight: bold;"><i class="fa-solid fa-gamepad"></i> ACC ĐANG ĐỢI BÁN</div>
                <div style="font-size: 32px; font-weight: 900; margin-top: 10px;"><%= new Intl.NumberFormat('vi-VN').format(stats.productCount) %> <span style="font-size: 16px; color: #888;">Acc</span></div>
            </div>

            <div style="background: var(--card); padding: 25px; border-radius: 12px; border-left: 4px solid #9b59b6;">
                <div style="color: #9a9a9a; font-size: 14px; font-weight: bold;"><i class="fa-solid fa-vault"></i> TỔNG SỐ DƯ TỒN ĐỌNG TRONG VÍ</div>
                <div style="font-size: 32px; font-weight: 900; margin-top: 10px; color: #9b59b6;"><%= new Intl.NumberFormat('vi-VN').format(stats.totalMoneyInSystem) %>đ</div>
            </div>
        </div>

        <div style="background: var(--card); padding: 25px; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.3);">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; border-bottom: 1px solid #444; padding-bottom: 15px;">
                <h3 style="margin: 0;"><i class="fa-solid fa-list-check" style="color: var(--warning);"></i> Lịch Sử Khách Tiêu Theo Lọc</h3>
                <div style="display: flex; gap: 15px;">
                    <div class="search-box">
                        <i class="fa-solid fa-magnifying-glass"></i>
                        <input type="text" id="searchInput" onkeyup="filterTable()" placeholder="Lọc theo Tên, Mô tả...">
                    </div>
                </div>
            </div>
            
            <div class="table-container" style="max-height: 600px; overflow-y: auto;">
                <table id="logsTable" style="width: 100%; border-collapse: collapse; color: #fff; font-size: 14px;">
                    <thead>
                        <tr style="text-align: left; background: #1a1a2e;">
                            <th style="padding: 15px 10px; color: #888; position: sticky; top: 0; background: #1a1a2e; z-index: 1;">Thời Gian</th>
                            <th style="padding: 15px 10px; color: #888; position: sticky; top: 0; background: #1a1a2e; z-index: 1;">Khách Hàng</th>
                            <th style="padding: 15px 10px; color: #888; position: sticky; top: 0; background: #1a1a2e; z-index: 1;">Phân Loại</th>
                            <th style="padding: 15px 10px; color: #888; position: sticky; top: 0; background: #1a1a2e; z-index: 1;">Mô Tả Chi Tiết</th>
                            <th style="padding: 15px 10px; color: #888; position: sticky; top: 0; background: #1a1a2e; z-index: 1; text-align: right;">Biến Động</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if(typeof recentActivities !== 'undefined' && recentActivities.length > 0) { %>
                            <% recentActivities.forEach(act => { 
                                let badgeClass = 'bdg-default';
                                let typeName = act.act_type;
                                
                                if(act.act_type === 'topup' || act.act_type === 'bank_transfer' || act.act_type === 'card' || act.act_type === 'recharge') { badgeClass = 'bdg-deposit'; typeName = 'Khách Nạp'; }
                                else if(act.act_type === 'admin_add' || act.act_type === 'admin_adjust') { badgeClass = 'bdg-admin'; typeName = 'Admin Thao Tác'; }
                                else if(act.act_type === 'MUA_ACC' || act.act_type === 'buy_acc') { badgeClass = 'bdg-buy'; typeName = 'Mua Nick'; }
                                else if(act.act_type === 'buy_box' || act.act_type === 'tui_mu' || act.act_type === 'TÚI MÙ') { badgeClass = 'bdg-game'; typeName = 'Mua Túi Mù'; }
                                else if(act.act_type === 'buy_xinxam') { badgeClass = 'bdg-game'; typeName = 'Gieo Quẻ'; }
                                else if(act.act_type === 'book_boost') { badgeClass = 'bdg-game'; typeName = 'Cày Thuê'; }
                                else if(act.act_type === 'rent_acc') { badgeClass = 'bdg-game'; typeName = 'Thuê Acc'; }
                                else if(act.act_type === 'vip_reward') { badgeClass = 'bdg-game'; typeName = 'Đổi Quà VIP'; }
                                else if(act.act_type === 'refund') { badgeClass = 'bdg-refund'; typeName = 'Hoàn Tiền'; }
                            %>
                                <tr style="border-bottom: 1px solid rgba(255,255,255,0.05); transition: 0.2s;" onmouseover="this.style.background='rgba(255,255,255,0.03)'" onmouseout="this.style.background='transparent'">
                                    <td style="padding: 15px 10px; color: #aaa; font-size: 13px;"><%= new Date(act.created_at).toLocaleString('vi-VN') %></td>
                                    <td style="padding: 15px 10px; font-weight: bold; color: var(--primary);"><i class="fa-solid fa-user" style="font-size: 10px; color: #555;"></i> <%= act.username %></td>
                                    <td style="padding: 15px 10px;"><span class="badge <%= badgeClass %>"><%= typeName %></span></td>
                                    <td style="padding: 15px 10px; color: #ddd; max-width: 300px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;" title="<%= act.detail %>"><%= act.detail || 'Không có mô tả' %></td>
                                    <td style="padding: 15px 10px; text-align: right;">
                                        <% if (act.amount > 0) { %>
                                            <span class="amount-plus">+<%= new Intl.NumberFormat('vi-VN').format(act.amount) %>đ</span>
                                        <% } else if (act.amount < 0) { %>
                                            <span class="amount-minus"><%= new Intl.NumberFormat('vi-VN').format(act.amount) %>đ</span>
                                        <% } else { %>
                                            <span style="color: #888;">0đ</span>
                                        <% } %>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr><td colspan="5" style="text-align: center; padding: 40px; color: #666;">Chưa có hoạt động nào trong khung giờ này.</td></tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>

    </div>

    <script>
        function filterTable() {
            let input = document.getElementById("searchInput");
            let filter = input.value.toUpperCase();
            let table = document.getElementById("logsTable");
            let tr = table.getElementsByTagName("tr");
            for (let i = 1; i < tr.length; i++) {
                tr[i].style.display = "none";
                let tdArray = tr[i].getElementsByTagName("td");
                for (let j = 1; j <= 3; j++) {
                    if (tdArray[j]) {
                        let txtValue = tdArray[j].textContent || tdArray[j].innerText;
                        if (txtValue.toUpperCase().indexOf(filter) > -1) {
                            tr[i].style.display = ""; break;
                        }
                    }
                }
            }
        }
    </script>
</body>
</html>