<!DOCTYPE html>
<html lang="vi">
<head>
    <title>Chi tiết: <%= targetUser.username %></title>
    <meta name="csrf-token" content="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
    
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <%- include('partials/admin_css') %>
</head>
<body>
    <%- include('partials/sidebar', { page: 'users' }) %>

    <div class="main-content">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px;">
            <h1 style="margin: 0; font-weight: 300; border-left: 4px solid var(--accent); padding-left: 15px;">Hồ Sơ: <%= targetUser.username %></h1>
            <a href="/admin/users" style="color: #aaa; text-decoration: none;"><i class="fa-solid fa-arrow-left"></i> Quay lại danh sách</a>
        </div>

        <div class="grid-2">
            <div>
                <div class="card" style="text-align: center; border-top: 4px solid #3498db;">
                    <div style="width: 80px; height: 80px; background: #3498db; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 35px; margin: 0 auto 15px;">
                        <i class="fa-solid fa-user"></i>
                    </div>
                    <h2 style="margin: 0 0 5px 0;"><%= targetUser.username %></h2>
                    <p style="margin: 0; color: #888; font-size: 13px;">ID: #<%= targetUser.id %> | Khởi tạo: <%= new Date(targetUser.created_at).toLocaleDateString('vi-VN') %></p>
                    <h1 style="color: #2ecc71; margin: 15px 0;"><%= new Intl.NumberFormat('vi-VN').format(targetUser.money) %>đ</h1>
                </div>

                <div class="card">
                    <h3><i class="fa-solid fa-coins"></i> Cộng / Trừ Tiền</h3>
                    <div class="form-group">
                        <label>Số tiền (VNĐ)</label>
                        <input type="number" id="adj-amount" placeholder="VD: 50000">
                    </div>
                    <div class="form-group">
                        <label>Lý do (Ghi chú dòng tiền)</label>
                        <input type="text" id="adj-reason" placeholder="Khuyến mãi sự kiện..." value="Admin hỗ trợ">
                    </div>
                    <div style="display: flex; gap: 10px;">
                        <button class="btn btn-green" onclick="adjustMoney('plus')"><i class="fa-solid fa-plus"></i> CỘNG</button>
                        <button class="btn btn-red" onclick="adjustMoney('minus')"><i class="fa-solid fa-minus"></i> TRỪ</button>
                    </div>
                </div>

                <div class="card">
                    <h3><i class="fa-solid fa-key"></i> Đổi mật khẩu Khách</h3>
                    <div class="form-group">
                        <input type="text" id="new-password" placeholder="Nhập mật khẩu mới...">
                    </div>
                    <button class="btn btn-blue" onclick="changePassword()"><i class="fa-solid fa-floppy-disk"></i> LƯU MẬT KHẨU</button>
                </div>

                <div class="card" style="border-color: #e74c3c;">
                    <h3 style="color: #e74c3c;"><i class="fa-solid fa-ban"></i> Khóa Tài Khoản</h3>
                    <% if(targetUser.is_banned) { %>
                        <div style="background: rgba(231, 76, 60, 0.2); padding: 10px; border-radius: 6px; margin-bottom: 15px; color: #e74c3c; font-size: 13px;">
                            <b>Lý do khóa:</b> <%= targetUser.ban_reason %>
                        </div>
                        <button class="btn btn-green" onclick="banUser('unban')"><i class="fa-solid fa-unlock"></i> MỞ KHÓA NGAY</button>
                    <% } else { %>
                        <div class="form-group">
                            <input type="text" id="ban-reason" placeholder="Nhập lý do khóa nick...">
                        </div>
                        <button class="btn btn-red" onclick="banUser('ban')"><i class="fa-solid fa-lock"></i> KHÓA VĨNH VIỄN</button>
                    <% } %>
                </div>
            </div>

            <div>
                <div class="card" style="padding: 0; overflow: hidden;">
                    <h3 style="padding: 20px 20px 10px; margin: 0; background: #27293d; border-bottom: 1px solid #444;">
                        <i class="fa-solid fa-money-bill-transfer" style="color: #00f2c3;"></i> LỊCH SỬ DÒNG TIỀN (50 GIAO DỊCH GẦN NHẤT)
                    </h3>
                    
                    <div style="max-height: 400px; overflow-y: auto;">
                        <table class="cash-table">
                            <thead>
                                <tr>
                                    <th>Thời Gian</th>
                                    <th>Biến Động</th>
                                    <th>Chi Tiết Số Dư</th>
                                    <th>Nội Dung</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if(transactions.length > 0) { %>
                                    <% transactions.forEach(t => { %>
                                        <tr>
                                            <td style="color: #888; font-size: 12px;">
                                                <%= new Date(t.created_at).toLocaleString('vi-VN') %>
                                            </td>
                                            <td>
                                                <% if(t.amount > 0) { %>
                                                    <span class="amt-plus">+<%= new Intl.NumberFormat('vi-VN').format(t.amount) %>đ</span>
                                                <% } else { %>
                                                    <span class="amt-minus"><%= new Intl.NumberFormat('vi-VN').format(t.amount) %>đ</span>
                                                <% } %>
                                            </td>
                                            <td>
                                                <div class="balance-box">Trước: <%= new Intl.NumberFormat('vi-VN').format(t.old_balance !== null ? t.old_balance : 0) %>đ</div>
                                                <div class="balance-box">Sau: <span class="balance-val"><%= new Intl.NumberFormat('vi-VN').format(t.new_balance !== null ? t.new_balance : 0) %>đ</span></div>
                                            </td>
                                            <td>
                                                <% 
                                                    let badge = '';
                                                    if(t.type === 'deposit') badge = '<span style="background:rgba(46,204,113,0.2); color:#2ecc71; padding:2px 6px; border-radius:4px; font-size:10px; margin-right:5px;">Nạp Thẻ</span>';
                                                    else if(t.type === 'buy_acc') badge = '<span style="background:rgba(231,76,60,0.2); color:#e74c3c; padding:2px 6px; border-radius:4px; font-size:10px; margin-right:5px;">Mua Acc</span>';
                                                    else if(t.type === 'admin_adjust') badge = '<span style="background:rgba(52,152,219,0.2); color:#3498db; padding:2px 6px; border-radius:4px; font-size:10px; margin-right:5px;">Admin Q/Định</span>';
                                                    else badge = `<span style="background:rgba(241,196,15,0.2); color:#f1c40f; padding:2px 6px; border-radius:4px; font-size:10px; margin-right:5px;">${t.type.toUpperCase()}</span>`;
                                                %>
                                                <%- badge %> <%= t.description %>
                                            </td>
                                        </tr>
                                    <% }) %>
                                <% } else { %>
                                    <tr><td colspan="4" style="text-align:center; padding:30px; color:#666;">Chưa có phát sinh dòng tiền nào.</td></tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="card">
                    <h3><i class="fa-solid fa-gamepad" style="color: #e14eca;"></i> TÀI KHOẢN GAME ĐÃ MUA</h3>
                    <% if(accOrders.length > 0) { %>
                        <% accOrders.forEach(o => { %>
                            <div class="acc-item">
                                <div class="acc-info">
                                    <img src="<%= o.image_url %>" onerror="this.src='/images/default.jpg'">
                                    <div>
                                        <b style="color: var(--accent);"><%= o.title %></b>
                                        <div style="font-size: 11px; color: #888;">Mua lúc: <%= new Date(o.created_at).toLocaleString('vi-VN') %> | Giá: <%= new Intl.NumberFormat('vi-VN').format(o.price_new) %>đ</div>
                                    </div>
                                </div>
                                <div class="acc-cred">
                                    TK: <%= o.acc_username %><br>
                                    MK: <%= o.acc_password %>
                                </div>
                            </div>
                        <% }) %>
                    <% } else { %>
                        <div style="text-align: center; padding: 20px; color: #666;">Khách này chưa mua nick nào!</div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>

    <script>
        const userId = <%= targetUser.id %>;
        const csrfToken = document.querySelector('meta[name="csrf-token"]').getAttribute('content');

        async function adjustMoney(type) {
            const amount = document.getElementById('adj-amount').value;
            const reason = document.getElementById('adj-reason').value || "Admin xử lý";
            
            if(!amount || amount <= 0) return alert("Vui lòng nhập số tiền lớn hơn 0");
            if(!confirm(`Xác nhận ${type === 'plus' ? 'CỘNG' : 'TRỪ'} ${parseInt(amount).toLocaleString('vi-VN')}đ cho user này?`)) return;

            try {
                const res = await fetch('/admin/users/money', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'CSRF-Token': csrfToken },
                    body: JSON.stringify({ userId, amount, type, reason })
                });
                const data = await res.json();
                alert(data.message);
                if(data.success) window.location.reload();
            } catch(e) { alert('Lỗi Server'); }
        }

        async function changePassword() {
            const newPassword = document.getElementById('new-password').value;
            if(newPassword.length < 6) return alert("Mật khẩu phải từ 6 ký tự!");

            try {
                const res = await fetch('/admin/users/password', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'CSRF-Token': csrfToken },
                    body: JSON.stringify({ userId, newPassword })
                });
                const data = await res.json();
                alert(data.message);
            } catch(e) { alert('Lỗi Server'); }
        }

        async function banUser(action) {
            let reason = "";
            if(action === 'ban') {
                reason = document.getElementById('ban-reason').value;
                if(!reason) return alert("Phải nhập lý do khóa nick!");
            }

            if(!confirm(`Bạn chắc chắn muốn ${action === 'ban' ? 'KHÓA' : 'MỞ KHÓA'} user này?`)) return;

            try {
                const res = await fetch('/admin/users/ban', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'CSRF-Token': csrfToken },
                    body: JSON.stringify({ userId, action, reason })
                });
                const data = await res.json();
                alert(data.message);
                if(data.success) window.location.reload();
            } catch(e) { alert('Lỗi Server'); }
        }
    </script>
</body>
</html>