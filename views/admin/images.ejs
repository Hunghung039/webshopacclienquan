<!DOCTYPE html>
<html lang="vi">
<head>
    <title>Quản Lý Hình Ảnh</title>
    <meta name="csrf-token" content="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
    <%- include('partials/admin_css') %>
    
    <style>
        /* ==========================================
           CSS RIÊNG CHO QUẢN LÝ ẢNH
           ========================================== */
        .upload-zone { border: 2px dashed #555; border-radius: 12px; padding: 40px 20px; text-align: center; background: #1a1a2e; transition: 0.3s; cursor: pointer; }
        .upload-zone:hover { border-color: var(--accent); background: rgba(0, 242, 195, 0.05); }
        
        /* Toolbar (Tìm kiếm & Thống kê) */
        .toolbar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; flex-wrap: wrap; gap: 15px; }
        .toolbar .search-box { margin-bottom: 0; max-width: 300px; width: 100%; }

        /* Lưới hiển thị ảnh */
        .image-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 20px; }
        .img-item { background: #1a1a2e; border: 1px solid #444; border-radius: 10px; overflow: hidden; position: relative; transition: 0.3s; display: flex; flex-direction: column;}
        .img-item:hover { transform: translateY(-5px); border-color: var(--accent); box-shadow: 0 5px 15px rgba(0, 242, 195, 0.2); z-index: 2;}
        
        .img-preview-container { height: 140px; overflow: hidden; background: #000; cursor: pointer; position: relative; }
        .img-preview { width: 100%; height: 100%; object-fit: cover; transition: 0.3s; }
        .img-preview-container:hover .img-preview { opacity: 0.7; transform: scale(1.05); }
        .img-preview-container::after { content: '\f00e'; font-family: 'Font Awesome 6 Free'; font-weight: 900; position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); color: #fff; font-size: 24px; opacity: 0; transition: 0.3s; pointer-events: none;}
        .img-preview-container:hover::after { opacity: 1; }
        
        .img-actions { padding: 12px; display: flex; gap: 8px; justify-content: space-between; margin-top: auto; border-top: 1px solid #333;}
        .btn-action { flex: 1; padding: 8px 0; text-align: center; border: none; border-radius: 6px; font-size: 12px; font-weight: bold; cursor: pointer; color: #fff; transition: 0.2s; display: flex; align-items: center; justify-content: center; gap: 5px;}
        .btn-copy { background: rgba(0, 242, 195, 0.2); color: var(--accent); border: 1px solid var(--accent);}
        .btn-copy:hover { background: var(--accent); color: #000; }
        .btn-del-img { background: rgba(253, 93, 147, 0.1); color: var(--danger); border: 1px solid var(--danger); }
        .btn-del-img:hover { background: var(--danger); color: #fff; }
        
        .filename-tooltip { font-size: 11px; color: #ccc; padding: 10px 12px 5px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; font-family: monospace;}
        .folder-badge { font-size: 9px; padding: 3px 6px; border-radius: 4px; font-weight: bold; margin: 0 12px 10px; display: inline-block; width: fit-content;}
        .folder-new { background: rgba(52, 152, 219, 0.2); color: #3498db; border: 1px solid #3498db; }
        .folder-old { background: rgba(241, 196, 15, 0.2); color: #f1c40f; border: 1px solid #f1c40f; }

        /* Modal Phóng To Ảnh (Lightbox) */
        .modal-img { display: none; position: fixed; z-index: 9999; padding-top: 50px; left: 0; top: 0; width: 100%; height: 100%; overflow: auto; background-color: rgba(0,0,0,0.9); backdrop-filter: blur(5px);}
        .modal-content-img { margin: auto; display: block; max-width: 90%; max-height: 80vh; border-radius: 8px; box-shadow: 0 0 30px rgba(0,0,0,0.8); animation: zoomIn 0.3s;}
        .close-modal { position: absolute; top: 15px; right: 35px; color: #f1f1f1; font-size: 40px; font-weight: bold; transition: 0.3s; cursor: pointer; }
        .close-modal:hover, .close-modal:focus { color: var(--danger); text-decoration: none; cursor: pointer; }
        #caption { margin: auto; display: block; width: 80%; max-width: 700px; text-align: center; color: #ccc; padding: 10px 0; height: 150px; font-family: monospace; font-size: 14px;}
        @keyframes zoomIn { from {transform:scale(0)} to {transform:scale(1)} }

        @media (max-width: 768px) {
            .image-grid { grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); }
            .img-preview-container { height: 110px; }
            .btn-action span { display: none; /* Ẩn chữ trên đt, chỉ hiện icon */ }
            .modal-content-img { width: 95%; max-height: 70vh;}
        }
    </style>
</head>
<body>
    <%- include('partials/sidebar', { page: 'images' }) %>

    <div class="main-content">
        <h1 class="page-title"><i class="fa-solid fa-images"></i> Kho Lưu Trữ Hình Ảnh Media</h1>
        
        <div class="card" style="border-top: 4px solid var(--accent);">
            <h3 style="margin-top:0; color:var(--accent); font-size:16px;"><i class="fa-solid fa-cloud-arrow-up"></i> Tải Ảnh Mới Lên Máy Chủ</h3>
            <form id="uploadForm">
                <input type="file" id="fileInput" accept="image/*" multiple style="display: none;">
                <div class="upload-zone" onclick="document.getElementById('fileInput').click()">
                    <i class="fa-regular fa-image" style="font-size: 40px; color: #888; margin-bottom: 10px;"></i>
                    <p style="margin: 0; color: #fff; font-size: 16px; font-weight: bold;">Kéo thả ảnh vào đây hoặc Click để chọn ảnh</p>
                    <p style="margin: 5px 0 0 0; font-size: 13px; color: #aaa;">(Hỗ trợ chọn NHIỀU ẢNH cùng lúc. Ảnh sẽ tự động lưu và nén)</p>
                </div>
            </form>
        </div>

        <div class="card">
            <div class="toolbar">
                <h3 style="margin: 0; color: #fff; font-size:16px;">
                    <i class="fa-solid fa-folder-open" style="color: var(--warning);"></i> 
                    Ảnh đã tải lên (<span id="totalImages"><%= images.length %></span>)
                </h3>
                
                <div class="search-box">
                    <i class="fa-solid fa-magnifying-glass"></i>
                    <input type="text" id="searchInput" placeholder="Tìm tên ảnh..." onkeyup="filterImages()">
                </div>
            </div>
            
            <div class="image-grid" id="imageGrid">
                <% images.forEach(img => { %>
                    <% 
                        let imgPath = '/' + img.folder + '/' + img.name; 
                        let fullUrl = domain + imgPath;
                    %>
                    <div class="img-item" id="item-<%= img.name %>" data-name="<%= img.name.toLowerCase() %>">
                        <div class="img-preview-container" onclick="openModal('<%= imgPath %>', '<%= img.name %>', '<%= fullUrl %>')">
                            <img src="<%= imgPath %>" class="img-preview" alt="<%= img.name %>" loading="lazy">
                        </div>
                        
                        <div class="filename-tooltip" title="<%= img.name %>"><%= img.name %></div>
                        
                        <% if(img.folder === 'images') { %>
                            <div class="folder-badge folder-new"><i class="fa-solid fa-bolt"></i> Mới</div>
                        <% } else { %>
                            <div class="folder-badge folder-old"><i class="fa-solid fa-clock-rotate-left"></i> Cũ</div>
                        <% } %>

                        <div class="img-actions">
                            <button class="btn-action btn-copy" onclick="copyLink('<%= fullUrl %>')" title="Copy Link">
                                <i class="fa-solid fa-link"></i> <span>Copy</span>
                            </button>
                            <button class="btn-action btn-del-img" onclick="deleteImage('<%= img.name %>', '<%= img.folder %>')" title="Xóa Ảnh">
                                <i class="fa-solid fa-trash"></i> <span>Xóa</span>
                            </button>
                        </div>
                    </div>
                <% }) %>
            </div>

            <% if(images.length === 0) { %>
                <div style="text-align:center; padding: 50px; color:#666; border: 1px dashed #444; border-radius: 8px; margin-top: 20px;">
                    <i class="fa-regular fa-image" style="font-size: 40px; margin-bottom: 15px; display: block;"></i>
                    Chưa có hình ảnh nào trong kho.
                </div>
            <% } %>
        </div>
    </div>

    <div id="imageModal" class="modal-img">
        <span class="close-modal" onclick="closeModal()">&times;</span>
        <img class="modal-content-img" id="img01">
        <div id="caption">
            <span id="caption-text"></span><br>
            <button class="btn-action btn-copy" style="width: fit-content; margin: 10px auto; padding: 8px 15px;" onclick="copyModalLink()">
                <i class="fa-solid fa-copy"></i> Copy Link Nhanh
            </button>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        const csrfToken = document.querySelector('meta[name="csrf-token"]').getAttribute('content');
        let currentModalUrl = "";

        // ==========================================
        // 1. TỰ ĐỘNG UPLOAD NHIỀU ẢNH LẦN LƯỢT
        // ==========================================
        document.getElementById('fileInput').addEventListener('change', async function(e) {
            const files = this.files;
            if(files.length === 0) return;
            
            const zone = document.querySelector('.upload-zone');
            const originalHTML = zone.innerHTML;
            
            zone.innerHTML = `<i class="fa-solid fa-spinner fa-spin" style="font-size:40px; color:var(--accent);"></i>
                              <p style="margin-top:15px; font-weight:bold; color:var(--accent);" id="uploadProgress">Đang xử lý 1 / ${files.length} ảnh...</p>`;

            let successCount = 0;
            let errorCount = 0;

            // Dùng vòng lặp for...of để up từng ảnh một, tránh sập Server do up quá nhiều cùng lúc
            for(let i = 0; i < files.length; i++) {
                document.getElementById('uploadProgress').innerText = `Đang tải lên ảnh ${i + 1} / ${files.length}...`;
                
                const formData = new FormData();
                formData.append('image_file', files[i]);

                try {
                    const res = await fetch('/admin/images/upload', {
                        method: 'POST',
                        headers: { 'CSRF-Token': csrfToken },
                        body: formData
                    });
                    const data = await res.json();
                    if(data.success) successCount++;
                    else errorCount++;
                } catch(err) {
                    errorCount++;
                }
            }

            // Hoàn thành
            Swal.fire({
                icon: successCount > 0 ? 'success' : 'error',
                title: 'Hoàn tất tải lên!',
                text: `Thành công: ${successCount} ảnh. Lỗi: ${errorCount} ảnh.`,
                background: '#27293d',
                color: '#fff',
                confirmButtonColor: '#00f2c3'
            }).then(() => {
                window.location.reload();
            });
        });

        // ==========================================
        // 2. LỌC / TÌM KIẾM ẢNH NHANH (LIVE SEARCH)
        // ==========================================
        function filterImages() {
            const input = document.getElementById('searchInput').value.toLowerCase();
            const items = document.querySelectorAll('.img-item');
            let visibleCount = 0;

            items.forEach(item => {
                const name = item.getAttribute('data-name');
                if (name.includes(input)) {
                    item.style.display = 'flex';
                    visibleCount++;
                } else {
                    item.style.display = 'none';
                }
            });
            
            document.getElementById('totalImages').innerText = visibleCount;
        }

        // ==========================================
        // 3. COPY LINK MƯỢT MÀ VỚI SWEETALERT
        // ==========================================
        function copyLink(url) {
            navigator.clipboard.writeText(url).then(() => {
                Swal.fire({ toast: true, position: 'top-end', icon: 'success', title: 'Đã copy link ảnh!', showConfirmButton: false, timer: 2000, background: '#27293d', color: '#fff' });
            }).catch(() => {
                Swal.fire('Lỗi', 'Trình duyệt không hỗ trợ copy tự động!', 'error');
            });
        }

        // ==========================================
        // 4. XÓA ẢNH (BẢO VỆ BẰNG CONFIRM)
        // ==========================================
        async function deleteImage(filename, folderName) {
            Swal.fire({
                title: 'Xóa vĩnh viễn?',
                text: "Ảnh bị xóa sẽ làm các bài viết chứa ảnh này bị lỗi hiển thị!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#fd5d93',
                cancelButtonColor: '#555',
                confirmButtonText: 'Đồng ý, Xóa!',
                cancelButtonText: 'Hủy',
                background: '#27293d',
                color: '#fff'
            }).then(async (result) => {
                if (result.isConfirmed) {
                    try {
                        const res = await fetch('/admin/images/delete', {
                            method: 'POST',
                            headers: { 
                                'Content-Type': 'application/json',
                                'CSRF-Token': csrfToken
                            },
                            body: JSON.stringify({ filename: filename, folder: folderName })
                        });
                        const data = await res.json();
                        
                        if(data.success) {
                            const el = document.getElementById('item-' + filename);
                            el.style.transform = 'scale(0)';
                            el.style.opacity = '0';
                            setTimeout(() => {
                                el.remove();
                                // Cập nhật lại số lượng
                                const countEl = document.getElementById('totalImages');
                                countEl.innerText = parseInt(countEl.innerText) - 1;
                            }, 300);
                            
                            Swal.fire({ toast: true, position: 'top-end', icon: 'success', title: 'Đã xóa ảnh', showConfirmButton: false, timer: 2000, background: '#27293d', color: '#fff' });
                        } else {
                            Swal.fire('Lỗi', data.message, 'error');
                        }
                    } catch(err) {
                        Swal.fire('Lỗi', 'Mất kết nối máy chủ!', 'error');
                    }
                }
            });
        }

        // ==========================================
        // 5. LIGHTBOX / MODAL XEM TRƯỚC ẢNH
        // ==========================================
        const modal = document.getElementById("imageModal");
        const modalImg = document.getElementById("img01");
        const captionText = document.getElementById("caption-text");

        function openModal(imgSrc, imgName, fullUrl) {
            modal.style.display = "block";
            modalImg.src = imgSrc;
            captionText.innerText = imgName;
            currentModalUrl = fullUrl;
            document.body.style.overflow = 'hidden'; // Chống cuộn trang ở dưới
        }

        function closeModal() {
            modal.style.display = "none";
            document.body.style.overflow = 'auto';
        }

        function copyModalLink() {
            copyLink(currentModalUrl);
        }

        // Đóng modal khi click ra ngoài ảnh
        window.onclick = function(event) {
            if (event.target == modal) {
                closeModal();
            }
        }
    </script>
</body>
</html>