<!DOCTYPE html>
<html lang="vi">

<%- include('../../includes/head', locals) %>

<body>

    <%- include('../../includes/ui-common') %>
    <%- include('../../includes/header') %>
    <%- include('../../includes/mobile-nav') %>

    <main>


        <section class="container" id="nap-the" style="margin-top: 40px;">
            <div class="section-head">
                <h2>NẠP THẺ <span>CHIẾT KHẤU CAO</span></h2>
                <p>Nạp Quân Huy - Nạp Kim Cương Free Fire Tự Động 24/7</p>
            </div>
            <div class="recharge-wrapper">
                <%- include('../../includes/partials/recharge-form') %>
            </div>
        </section>

        <section class="container" style="margin-top: 60px;">
            </section>

        <section class="container" style="margin-top: 60px;" id="shop-acc">
            <div class="section-head">
                <h2>KHO ACC <span>LIÊN QUÂN GEN Z</span></h2>
                <p>Mua Acc Liên Quân Giá Rẻ - Acc Trắng Thông Tin</p>
            </div>

            <div class="product-list" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 20px;">
                <% if (typeof products !== 'undefined' && products.length > 0) { %>
                    <% products.forEach(function(product) { %>
                        <div class="product-card" style="background: #fff; border-radius: 15px; overflow: hidden; box-shadow: 0 5px 15px rgba(0,0,0,0.05); transition: 0.3s;">
                            
                            <a href="/chi-tiet/<%= product.slug %>" style="display: block; position: relative;">
                                <img src="<%= product.image_url %>" alt="Acc Liên Quân <%= product.title %>" loading="lazy" style="width: 100%; height: 160px; object-fit: cover;">
                                <span style="position: absolute; top: 10px; left: 10px; background: rgba(0,0,0,0.7); color: #fff; padding: 3px 8px; border-radius: 5px; font-size: 12px; font-weight: bold;">MS: <%= product.id %></span>
                            </a>

                            <div style="padding: 15px;">
                                <h3 style="font-size: 15px; margin: 0 0 10px 0; line-height: 1.4; height: 42px; overflow: hidden;">
                                    <a href="/chi-tiet/<%= product.slug %>" style="color: #2d3436; text-decoration: none;"><%= product.title %></a>
                                </h3>
                                
                                <div style="display: flex; justify-content: space-between; align-items: flex-end; margin-top: 15px;">
                                    <div>
                                        <% if (product.price_old > product.price_new) { %>
                                            <del style="font-size: 12px; color: #999;"><%= new Intl.NumberFormat('vi-VN').format(product.price_old) %>đ</del>
                                        <% } %>
                                        <div style="color: #e74c3c; font-size: 18px; font-weight: 900;"><%= new Intl.NumberFormat('vi-VN').format(product.price_new) %>đ</div>
                                    </div>
                                    <button class="btn btn-primary" onclick="openBuyModal('<%= product.title %>', '<%= new Intl.NumberFormat('vi-VN').format(product.price_new) %>đ')" style="padding: 8px 15px; font-size: 13px; font-weight: bold; border-radius: 8px;">MUA NGAY</button>
                                </div>
                            </div>

                        </div>
                    <% }); %>
                <% } else { %>
                    <div style="grid-column: 1 / -1; text-align: center; padding: 50px; color: #999; background: #fff; border-radius: 15px;">
                        <i class="fa-solid fa-box-open" style="font-size: 40px; margin-bottom: 15px; opacity: 0.5;"></i>
                        <p>Đang cập nhật thêm nick mới. Bạn vui lòng quay lại sau nhé!</p>
                    </div>
                <% } %>
            </div>

            <% if (typeof pagination !== 'undefined' && pagination.totalPages > 1) { %>
            <div class="pagination" style="display:flex; justify-content:center; gap:10px; margin-top:40px;">
                
                <% if (pagination.page > 1) { %>
                    <a href="/?page=<%= pagination.page - 1 %>#shop-acc" class="btn btn-secondary" style="padding: 8px 15px; border-radius: 8px; text-decoration: none; color: #333; background: #eee;">Quay lại</a>
                <% } %>
                
                <% for(let i = 1; i <= pagination.totalPages; i++) { %>
                    <a href="/?page=<%= i %>#shop-acc" class="btn" 
                       style="width: 40px; text-align: center; padding: 8px 0; border-radius: 8px; text-decoration: none; <%= pagination.page == i ? 'background: var(--primary); color: #fff;' : 'background: #eee; color: #333;' %>">
                        <%= i %>
                    </a>
                <% } %>
                
                <% if (pagination.page < pagination.totalPages) { %>
                    <a href="/?page=<%= pagination.page + 1 %>#shop-acc" class="btn btn-secondary" style="padding: 8px 15px; border-radius: 8px; text-decoration: none; color: #333; background: #eee;">Tiếp theo</a>
                <% } %>
                
            </div>
            <% } %>

        </section>
    </main>

    <%- include('../../includes/footer') %>
    <%- include('../../includes/modals') %>
    <%- include('../../includes/scripts') %>

</body>
</html>