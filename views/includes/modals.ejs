<div class="modal-overlay" id="buy-modal" style="display: none;">
    <div class="modal-box">
        <div class="modal-icon">
            <i class="fa-solid fa-cart-shopping"></i>
        </div>
        <h3>XÁC NHẬN MUA</h3>
        
        <div class="modal-info">
            <p>Sản phẩm: <b id="m-name" style="color:var(--primary)">...</b></p>
            <p>Giá tiền: <b id="m-price" style="color:#e74c3c">...</b></p>
        </div>

        <div style="margin: 15px 0;">
            <input type="text" class="guest-input" placeholder="Nhập Zalo/Facebook để CSKH liên hệ (Nếu cần)" style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 5px;">
        </div>
        
        <div class="modal-actions">
            <button class="btn btn-secondary" onclick="closeModal()">Hủy Bỏ</button>
            <button class="btn btn-primary" id="btn-confirm-buy">MUA NGAY</button>
        </div>
    </div>
</div>

<div class="modal-overlay" id="event-modal" style="display: none;">
    <div class="modal-box">
        <i class="fa-solid fa-gift" style="font-size:40px; color:var(--primary); margin-bottom:10px;"></i>
        <h3>THÔNG TIN NHẬN ĐIỂM</h3>
        
        <div style="background:#f8f9fa; padding:10px; border-radius:10px; margin:15px 0; text-align:left;">
            <p style="font-size:13px;">Gói mua: <b id="e-name" style="color:var(--primary)">...</b></p>
            <p style="font-size:13px;">Giá tiền: <b id="e-price" style="color:#e74c3c">...</b></p>
        </div>

        <form id="form-event-submit">
            <input type="hidden" id="e-type" name="packageType">
            
            <div class="input-group" style="text-align:left; margin-bottom:10px;">
                <label style="font-weight:700; font-size:12px; margin-left:5px;">TÊN INGAME:</label>
                <input type="text" id="e-ingame" name="ingameName" class="guest-input" placeholder="Nhập chính xác tên..." required style="margin-top:5px; border:1px solid #ddd;">
            </div>

            <div class="input-group" style="text-align:left; margin-bottom:15px;">
                <label style="font-weight:700; font-size:12px; margin-left:5px;">MÃ SỰ KIỆN:</label>
                <input type="text" id="e-code" name="eventCode" class="guest-input" placeholder="Copy mã sự kiện..." required style="margin-top:5px; border:2px solid var(--primary);">
            </div>
            
            <button type="submit" class="btn btn-primary full-width">XÁC NHẬN</button>
        </form>
        
        <button class="btn btn-secondary full-width" style="margin-top:10px;" onclick="closeEventModal()">ĐÓNG</button>
    </div>
</div>

<style>
    .modal-overlay {
        position: fixed; top: 0; left: 0; width: 100%; height: 100%;
        background: rgba(0,0,0,0.6); z-index: 10000;
        display: flex; align-items: center; justify-content: center;
        backdrop-filter: blur(5px);
    }
    .modal-box {
        background: #fff; width: 400px; padding: 30px; border-radius: 20px;
        text-align: center; box-shadow: 0 20px 50px rgba(0,0,0,0.3);
        animation: zoomIn 0.3s ease;
    }
    .modal-icon {
        width: 80px; height: 80px; background: #e14eca; border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        margin: 0 auto 20px; font-size: 35px; color: #fff;
    }
    .modal-info { background: #f8f9fa; padding: 15px; border-radius: 10px; margin: 20px 0; }
    .modal-actions { display: flex; gap: 10px; justify-content: center; }
    .btn { padding: 12px 25px; border: none; border-radius: 8px; cursor: pointer; font-weight: bold; }
    .btn-primary { background: #e14eca; color: #fff; }
    .btn-secondary { background: #eee; color: #333; }
    .full-width { width: 100%; }
    
    @keyframes zoomIn { from { transform: scale(0.5); opacity: 0; } to { transform: scale(1); opacity: 1; } }
</style>