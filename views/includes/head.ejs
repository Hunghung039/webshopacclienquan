<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
<link rel="icon" href="/images/favicon.ico" type="image/x-icon">

    <style>
        /* =========================================================================
           1. CORE VARIABLES (THEME CONFIG)
           ========================================================================= */
        :root {
            /* Palette: Pastel Dream & Neon Pop */
            --primary: #8e44ad;       /* Tím Chủ Đạo */
            --primary-dark: #703688;
            --primary-light: #a569bd;
            --secondary: #00cec9;     /* Xanh Cyan (Nổi bật) */
            --accent: #fd79a8;        /* Hồng Phấn (Điểm nhấn) */
            --warning: #fdcb6e;       /* Vàng Cam */
            --danger: #ff7675;        /* Đỏ Nhạt */
            --success: #00b894;       /* Xanh Lá */
            --dark: #2d3436;          /* Đen Xám */
            --light: #dfe6e9;         /* Xám Trắng */
            --live-red: #e74c3c;      /* Đỏ Livestream */
            
            /* Game UI variables (Gộp từ đoạn 1) */
            --game-bg: #f4f7f6; 
            --game-primary: #e74c3c; 
            --game-gold: #f1c40f;
            
            /* Backgrounds */
            --bg-body: #f0f3f8;
            --bg-glass: rgba(255, 255, 255, 0.85);
            --bg-glass-strong: rgba(255, 255, 255, 0.95);
            
            /* Gradients */
            --grad-primary: linear-gradient(135deg, #8e44ad 0%, #9b59b6 100%);
            --grad-hot: linear-gradient(45deg, #ff7675, #e84393);
            --grad-vip: linear-gradient(135deg, #f1c40f 0%, #f39c12 100%);
            --grad-live: linear-gradient(to right, #e74c3c, #c0392b);
            
            /* Spacing & Layout */
            --container-width: 1200px;
            --header-height: 70px;
            --radius-sm: 8px;
            --radius-md: 16px;
            --radius-lg: 24px;
            --radius-xl: 40px;
            
            /* Shadows & Effects */
            --shadow-sm: 0 4px 6px rgba(142, 68, 173, 0.1);
            --shadow-md: 0 10px 30px rgba(142, 68, 173, 0.15);
            --shadow-lg: 0 15px 40px rgba(142, 68, 173, 0.2);
            --shadow-float: 0 20px 50px rgba(0, 0, 0, 0.12);
            --border-glass: 1px solid rgba(255, 255, 255, 0.6);
            --blur: blur(16px);
            
            /* Transitions */
            --ease: cubic-bezier(0.23, 1, 0.32, 1);
            --duration: 0.3s;
        }

        /* =========================================================================
           2. RESET & BASE STYLES
           ========================================================================= */
        * { margin: 0; padding: 0; box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
        
        body {
            font-family: 'Be Vietnam Pro', sans-serif;
            background-color: var(--bg-body);
            color: var(--dark);
            line-height: 1.6;
            overflow-x: hidden;
            /* Animated Background */
            background-image: 
                radial-gradient(circle at 10% 10%, rgba(142, 68, 173, 0.08) 0%, transparent 50%),
                radial-gradient(circle at 90% 90%, rgba(0, 206, 201, 0.1) 0%, transparent 50%),
                radial-gradient(circle at 50% 50%, rgba(253, 121, 168, 0.05) 0%, transparent 50%);
            background-attachment: fixed;
            min-height: 100vh;
            padding-bottom: 80px; /* Space for Mobile Nav */
        }

        /* Scrollbar Customization */
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: #f1f1f1; }
        ::-webkit-scrollbar-thumb { background: var(--primary-light); border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: var(--primary); }

        /* Generic Elements */
        a { text-decoration: none; color: inherit; transition: all var(--duration) var(--ease); }
        ul { list-style: none; }
        img { max-width: 100%; display: block; border-radius: var(--radius-sm); }
        button, input, select, textarea { font-family: inherit; border: none; outline: none; }

        .container { max-width: var(--container-width); margin: 0 auto; padding: 0 16px; position: relative; z-index: 2; }
        .hidden { display: none !important; }
        .text-center { text-align: center; }
        .flex-center { display: flex; align-items: center; justify-content: center; }
        .full-width { width: 100%; }

        /* Canvas Overlay */
        #effects-canvas { position: fixed; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; z-index: 0; }

        /* =========================================================================
           3. UI COMPONENTS & UTILITIES
           ========================================================================= */
        /* Buttons */
        .btn {
            display: inline-flex; align-items: center; justify-content: center; gap: 8px;
            padding: 12px 24px; font-weight: 700; border-radius: var(--radius-xl);
            cursor: pointer; transition: transform 0.2s var(--ease), box-shadow 0.2s var(--ease);
            font-size: 15px; position: relative; overflow: hidden;
        }
        .btn:active { transform: scale(0.95); }
        
        .btn-primary {
            background: var(--grad-primary); color: #fff;
            box-shadow: 0 4px 15px rgba(142, 68, 173, 0.4);
        }
        .btn-primary:hover { box-shadow: 0 6px 20px rgba(142, 68, 173, 0.6); transform: translateY(-2px); }

        .btn-secondary {
            background: #fff; color: var(--primary); border: 2px solid var(--primary);
        }
        .btn-secondary:hover { background: var(--primary); color: #fff; }

        .btn-hot {
            background: var(--grad-hot); color: #fff;
            box-shadow: 0 4px 15px rgba(255, 118, 117, 0.4);
        }

        /* Section Headers */
        .section-head { text-align: center; margin-bottom: 40px; position: relative; }
        .section-head h2 { 
            font-size: 32px; font-weight: 900; margin-bottom: 8px; 
            background: -webkit-linear-gradient(45deg, var(--primary), var(--secondary));
            -webkit-background-clip: text; -webkit-text-fill-color: transparent;
            letter-spacing: -1px;
        }
        .section-head p { color: var(--text-sub); font-size: 15px; }
        .section-head::after {
            content: ''; display: block; width: 60px; height: 4px; 
            background: var(--secondary); border-radius: 4px; margin: 10px auto 0;
        }

        /* Glass Cards */
        .glass-card {
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: var(--blur); -webkit-backdrop-filter: var(--blur);
            border: var(--border-glass);
            border-radius: var(--radius-md);
            box-shadow: var(--shadow-sm);
        }

        /* =========================================================================
           4. HEADER & NAV (DESKTOP)
           ========================================================================= */
        .marquee-top {
            background: var(--grad-primary); color: #fff;
            font-size: 13px; font-weight: 700; padding: 8px 0;
            text-align: center; text-transform: uppercase; letter-spacing: 0.5px;
        }
        .marquee-top marquee { display: block; line-height: 1; }

        .header {
            position: sticky; top: 0; z-index: 100;
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(20px);
            border-bottom: 1px solid rgba(0,0,0,0.05);
            transition: all 0.3s;
        }
        .header-content {
            height: var(--header-height); display: flex; 
            justify-content: space-between; align-items: center;
        }
        .header-flex { display: flex; justify-content: space-between; align-items: center; width: 100%; }

        .logo { 
            font-size: 26px; font-weight: 900; color: var(--dark); text-transform: uppercase;
            letter-spacing: -1.5px; display: flex; align-items: center; gap: 8px;
            transition: transform 0.3s var(--ease); user-select: none;
        }
        .logo i { color: var(--primary); font-size: 28px; }
        .logo-accent {
            margin-left: 8px; color: var(--primary);
            background: linear-gradient(135deg, var(--primary) 0%, var(--accent) 100%);
            -webkit-background-clip: text; -webkit-text-fill-color: transparent;
            filter: drop-shadow(0 0 5px rgba(142, 68, 173, 0.3));
        }
        .logo img { object-fit: contain; transition: transform 0.3s var(--ease); }
        .logo:hover { transform: scale(1.05); }

        .nav-desktop { display: flex; gap: 30px; }
        .nav-item { font-weight: 600; color: #636e72; font-size: 15px; position: relative; padding: 5px 0; }
        .nav-item:hover, .nav-item.active { color: var(--primary); font-weight: 800;}
        .nav-item::after {
            content: ''; position: absolute; bottom: 0; left: 0; width: 0; height: 2px;
            background: var(--primary); transition: 0.3s; border-radius: 2px;
        }
        .nav-item:hover::after, .nav-item.active::after { width: 100%; }

        .header-actions { display: flex; gap: 10px; }
        .search-btn { font-size: 20px; color: var(--dark); cursor: pointer; padding: 8px; }

        /* Dropdown */
        .has-dropdown { position: relative; cursor: pointer; }
        .dropdown-menu {
            position: absolute; top: 100%; left: 0; min-width: 220px;
            background: var(--bg-glass-strong); backdrop-filter: var(--blur);
            border: var(--border-glass); border-radius: var(--radius-md); box-shadow: var(--shadow-lg);
            padding: 10px 0; list-style: none; z-index: 1000;
            opacity: 0; visibility: hidden; transform: translateY(15px); transition: all var(--duration) var(--ease);
        }
        .dropdown-right { left: auto; right: 0; }
        .has-dropdown:hover .dropdown-menu { opacity: 1; visibility: visible; transform: translateY(0); }
        .dropdown-menu li a { display: flex; align-items: center; gap: 12px; padding: 12px 20px; font-size: 14px; font-weight: 600; color: var(--dark); transition: 0.3s; }
        .dropdown-menu li a i { color: var(--primary); width: 20px; text-align: center; }
        .dropdown-menu li a:hover { background: rgba(142, 68, 173, 0.1); color: var(--primary); padding-left: 25px; }

        /* Profile Buttons */
        .btn-profile-action { padding: 8px 18px; border-radius: 20px; font-weight: bold; text-decoration: none; font-size: 13px; transition: 0.3s var(--ease); display: inline-flex; align-items: center; gap: 8px; }
        .logout-btn { background: #ffeaa7; color: #d35400; }
        .logout-btn:hover { background: #fdcb6e; transform: translateY(-2px); }
        .admin-btn { background: var(--grad-primary); color: #fff; box-shadow: 0 4px 12px rgba(142, 68, 173, 0.3); }
        .admin-btn:hover { box-shadow: 0 6px 20px rgba(142, 68, 173, 0.5); transform: translateY(-2px); filter: brightness(1.1); }

        /* =========================================================================
           5. MOBILE NAVIGATION & OVERLAY
           ========================================================================= */
        .mobile-bottom-nav {
            display: none; position: fixed; bottom: 0; left: 0; width: 100%;
            background: #fff; height: 65px; z-index: 999;
            box-shadow: 0 -5px 20px rgba(0,0,0,0.05); border-top: 1px solid #eee;
            justify-content: space-around; align-items: center;
        }
        .mb-item { display: flex; flex-direction: column; align-items: center; justify-content: center; color: #b2bec3; font-size: 10px; font-weight: 600; gap: 4px; width: 25%; height: 100%; }
        .mb-item i { font-size: 20px; transition: 0.2s; }
        .mb-item.active { color: var(--primary); }
        .mb-item.active i { transform: translateY(-2px); }
        .mb-center { position: relative; width: 22%; height: 100%; }
        .mb-center-btn {
            position: absolute; top: -25px; left: 50%; transform: translateX(-50%);
            width: 60px; height: 60px; border-radius: 50%; background: var(--grad-primary); border: 5px solid var(--bg-body);
            display: flex; flex-direction: column; align-items: center; justify-content: center;
            color: #fff; font-size: 24px; box-shadow: 0 8px 20px rgba(142, 68, 173, 0.4);
        }
        .mb-center-btn span { font-size: 9px; font-weight: 800; text-transform: uppercase; margin-top: 2px; }

        .category-overlay {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(30, 30, 47, 0.98); backdrop-filter: blur(15px); z-index: 10000;
            display: flex; flex-direction: column; padding: 25px;
            transform: translateY(100%); transition: transform 0.4s cubic-bezier(0.23, 1, 0.32, 1);
        }
        .category-overlay.active { transform: translateY(0); }
        .overlay-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px; }
        .close-btn { width: 45px; height: 45px; background: rgba(255,255,255,0.1); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #fff; font-size: 24px; cursor: pointer;}
        .overlay-title { color: var(--primary-light); font-size: 14px; font-weight: 800; letter-spacing: 2px; text-align: center; margin-bottom: 25px; text-transform: uppercase; }
        .category-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 15px; flex: 1; }
        .cat-card { background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: 20px; padding: 20px; text-align: center; text-decoration: none; transition: 0.3s; }
        .cat-card:active { transform: scale(0.95); background: rgba(142, 68, 173, 0.2); }
        .cat-icon { width: 50px; height: 50px; margin: 0 auto 10px; background-size: cover; background-position: center; }
        .cat-icon.lq { background-image: url('https://cdn-icons-png.flaticon.com/512/5260/5260498.png'); }
        .cat-icon.ff { background-image: url('https://cdn-icons-png.flaticon.com/512/5354/5354143.png'); }
        .cat-icon.tm { background-image: url('https://cdn-icons-png.flaticon.com/512/3082/3082031.png'); }
        .cat-icon.lb { background-image: url('https://cdn-icons-png.flaticon.com/512/1864/1864514.png'); }
        .cat-icon.vip { background-image: url('https://cdn-icons-png.flaticon.com/512/2583/2583344.png'); }
        .cat-icon.blog { background-image: url('https://cdn-icons-png.flaticon.com/512/1187/1187544.png'); }
        .cat-card span { color: #fff; font-size: 13px; font-weight: 700; display: block;}
        .overlay-footer { text-align: center; padding-top: 20px; color: #636e72; font-size: 12px; margin-top: auto;}
        .overlay-footer .social-links { display: flex; justify-content: center; gap: 20px; margin-top: 15px; font-size: 22px; color: var(--primary);}
        .social-links a { color: #fff; }
        body.no-scroll { overflow: hidden; }

        /* =========================================================================
           6. HERO SECTION (BANNER & EVENT)
           ========================================================================= */
        .hero { padding: 40px 0; text-align: center; position: relative; overflow: hidden; }
        .hero h1 { font-size: 42px; line-height: 1.2; margin-bottom: 15px; font-weight: 900; letter-spacing: -1px; }
        .hero-desc { font-size: 18px; color: #636e72; margin-bottom: 30px; }

        .event-box { max-width: 800px; margin: 0 auto; padding: 25px; background: #fff; border-radius: var(--radius-lg); box-shadow: var(--shadow-float); border: 1px solid rgba(255,255,255,0.5); position: relative; }
        .event-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px; }
        .event-badge { background: #ffeaa7; color: #d35400; padding: 4px 12px; border-radius: 20px; font-weight: 800; font-size: 12px; }
        
        .progress-track { height: 24px; background: #dfe6e9; border-radius: 12px; overflow: hidden; margin-bottom: 25px; box-shadow: inset 0 2px 5px rgba(0,0,0,0.05); }
        .progress-fill { height: 100%; background: linear-gradient(90deg, #fd79a8, #6c5ce7); width: 0%; border-radius: 12px; display: flex; align-items: center; justify-content: center; color: #fff; font-size: 11px; font-weight: 700; transition: width 1.5s ease-out; position: relative; }
        .progress-fill::after { content: ''; position: absolute; top: 0; left: 0; bottom: 0; right: 0; background-image: linear-gradient(-45deg,rgba(255,255,255,.2) 25%,transparent 25%,transparent 50%,rgba(255,255,255,.2) 50%,rgba(255,255,255,.2) 75%,transparent 75%,transparent); z-index: 1; background-size: 50px 50px; animation: move 2s linear infinite; }
        @keyframes move { 0% { background-position: 0 0; } 100% { background-position: 50px 50px; } }

        .pack-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 15px; }
        .pack-item { background: #f8f9fa; padding: 15px; border-radius: var(--radius-md); cursor: pointer; border: 2px solid transparent; transition: 0.3s; }
        .pack-item:hover, .pack-item.selected { background: #fff; border-color: var(--primary); transform: translateY(-5px); box-shadow: var(--shadow-sm); }
        .pack-item h4 { font-size: 13px; color: #636e72; }
        .pack-item .price { font-size: 18px; font-weight: 800; color: var(--primary); margin: 5px 0; }
        .btn-buy-pack { background: var(--primary); color: #fff; border: none; padding: 5px 15px; border-radius: 20px; font-weight: 700; font-size: 12px; margin-top: 8px; cursor: pointer; transition: 0.3s; }
        .pack-item:hover .btn-buy-pack { background: var(--secondary); box-shadow: 0 4px 10px rgba(0,0,0,0.2); }
        
        .live-noti { margin-top: 20px; font-size: 13px; color: #636e72; background: #f1f2f6; padding: 8px; border-radius: 30px; display: inline-block; }

        /* =========================================================================
           7. NẠP THẺ SECTION & TABLES
           ========================================================================= */
        .recharge-wrapper { background: #fff; border-radius: var(--radius-lg); overflow: hidden; box-shadow: var(--shadow-md); display: flex; flex-direction: column; }
        .tab-header { display: flex; background: #f8f9fa; border-bottom: 1px solid #eee; }
