
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0">
<meta name="csrf-token" content="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700;800;900&family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<% 
    // 1. THIẾT LẬP THÔNG TIN MẶC ĐỊNH
    let pageTitle = typeof title !== 'undefined' ? title : 'ShopLienQuan.Site - Mua Bán Acc & Dịch Vụ Liên Quân Uy Tín';
    let pageDesc = typeof description !== 'undefined' ? description : 'Hệ thống bán nick Liên Quân tự động 24/7, nạp thẻ, cày thuê, mua túi mù và vòng quay giá siêu rẻ. Uy tín hàng đầu Việt Nam.';
    let pageKeywords = typeof keywords !== 'undefined' ? keywords : 'shop liên quân, mua acc lq, shop acc uy tín, nạp quân huy giá rẻ, cày thuê liên quân, thuê nick liên quân, túi mù liên quân';
    let pageUrl = 'https://shoplienquan.site' + (typeof currentUrl !== 'undefined' ? currentUrl : '/');
    let shareImage = 'https://shoplienquan.site/images/banner-share.png'; 

    // 2. LOGIC TỰ ĐỘNG BẮT ẢNH SHARE LÊN FACEBOOK / ZALO
    if (typeof product !== 'undefined' && product.image_url) {
        shareImage = product.image_url.startsWith('http') ? product.image_url : 'https://shoplienquan.site' + product.image_url;
    } else if (typeof article !== 'undefined' && article.thumbnail) {
        shareImage = article.thumbnail.startsWith('http') ? article.thumbnail : 'https://shoplienquan.site' + article.thumbnail;
    } else if (typeof image !== 'undefined') {
        shareImage = image.startsWith('http') ? image : 'https://shoplienquan.site' + image;
    }
%>

<title><%= pageTitle %></title>
<meta name="description" content="<%= pageDesc %>">
<meta name="keywords" content="<%= pageKeywords %>">
<link rel="canonical" href="<%= pageUrl %>">

<meta property="og:type" content="<%= typeof article !== 'undefined' ? 'article' : 'website' %>">
<meta property="og:url" content="<%= pageUrl %>">
<meta property="og:title" content="<%= pageTitle %>">
<meta property="og:description" content="<%= pageDesc %>">
<meta property="og:image" content="<%= shareImage %>">
<meta property="og:image:width" content="1200">
<meta property="og:image:height" content="630">
<meta property="og:site_name" content="ShopLienQuan.Site">

<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="<%= pageTitle %>">
<meta name="twitter:description" content="<%= pageDesc %>">
<meta name="twitter:image" content="<%= shareImage %>">

<% if (typeof schemaData !== 'undefined') { %>
    <script type="application/ld+json">
        <%- schemaData %>
    </script>

<% } else if (typeof product !== 'undefined') { %>
    <script type="application/ld+json">
    {
      "@context": "https://schema.org/",
      "@type": "Product",
      "name": "<%= product.title %>",
      "image": "<%= shareImage %>",
      "description": "Tài khoản Liên Quân cực VIP, thông tin trắng, giá siêu rẻ. Giao dịch tự động uy tín tại ShopLienQuan.Site.",
      "brand": { "@type": "Brand", "name": "Liên Quân Mobile" },
      "offers": {
        "@type": "Offer",
        "url": "<%= pageUrl %>",
        "priceCurrency": "VND",
        "price": "<%= product.price_new %>",
        "itemCondition": "https://schema.org/UsedCondition",
        "availability": "https://schema.org/InStock",
        "seller": { "@type": "Organization", "name": "ShopLienQuan.Site" }
      }
    }
    </script>

<% } else if (typeof article !== 'undefined') { %>
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "NewsArticle",
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": "<%= pageUrl %>"
      },
      "headline": "<%= article.title %>",
      "image": [ "<%= shareImage %>" ],
      "datePublished": "<%= new Date(article.created_at).toISOString() %>",
      "author": { "@type": "Organization", "name": "ShopLienQuan", "url": "https://shoplienquan.site/" },
      "publisher": {
        "@type": "Organization",
        "name": "ShopLienQuan.Site",
        "logo": { "@type": "ImageObject", "url": "https://shoplienquan.site/images/logo.png" }
      }
    }
    </script>

<% } else { %>
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Organization",
          "@id": "https://shoplienquan.site/#organization",
          "name": "ShopLienQuan.Site",
          "url": "https://shoplienquan.site/",
          "logo": { "@type": "ImageObject", "url": "https://shoplienquan.site/images/logo.png" },
          "description": "Hệ thống mua bán Nick Liên Quân, Cày Thuê, Thuê Acc, Nạp Thẻ uy tín hàng đầu Việt Nam."
        },
        {
          "@type": "WebSite",
          "@id": "https://shoplienquan.site/#website",
          "url": "https://shoplienquan.site/",
          "name": "ShopLienQuan.Site",
          "publisher": { "@id": "https://shoplienquan.site/#organization" },
          "potentialAction": {
            "@type": "SearchAction",
            "target": "https://shoplienquan.site/tai-khoan?category={search_term_string}",
            "query-input": "required name=search_term_string"
          }
        }
      ]
    }
    </script>
<% } %>

