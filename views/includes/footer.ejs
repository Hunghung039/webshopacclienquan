<script>
    function toggleSocialMenu() {
        const menu = document.getElementById('socialMenuBox');
        const overlay = document.getElementById('socialOverlay');
        const btnIcon = document.querySelector('.social-hub-btn i');
        
        // Bật/tắt class active
        menu.classList.toggle('active');
        overlay.classList.toggle('active');
        
        // Đổi Icon từ Tai nghe sang dấu X và ngược lại
        if (menu.classList.contains('active')) {
            btnIcon.className = "fa-solid fa-xmark";
        } else {
            btnIcon.className = "fa-solid fa-headset";
        }
    }
</script>